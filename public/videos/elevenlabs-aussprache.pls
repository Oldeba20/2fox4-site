  alphabet="ipa" xml:lang="de-DE">

  <!-- HINWEIS: Für deutschen Text nutzt ElevenLabs ALIAS-Regeln (keine Phoneme).
       Jede Regel ersetzt das Wort durch eine lautmalerische Schreibweise,
       die das mehrsprachige Modell englisch-nah ausspricht.
       PLS ist case-sensitive – bei Bedarf Klein-/Großschreibung ergänzen. -->

