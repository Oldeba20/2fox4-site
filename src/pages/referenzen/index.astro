---
/**
 * /referenzen/ — Übersicht aller Projekt-Referenzen.
 * Filter-Pills (Alle / Webseiten / Onlineshops) per Vanilla-JS.
 * Karten verwenden MonitorCard in default-Variante (mit Hover-Zoom).
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import MonitorCard from "../../components/MonitorCard.astro";
import { references, referenceCounts } from "../../data/references";
import { breadcrumbSchema } from "../../lib/schema";

const title = "Referenzen — 2FOX4 Webdesign & Onlineshops aus 18 Jahren";
const description =
  "Eine Auswahl aus 18 Jahren Webdesign: WordPress, WooCommerce, Shopware, Oxid. Von Vereinswebsites bis zu KI-Tools.";

const counts = referenceCounts();

const schema = breadcrumbSchema([
  { name: "Start", url: "/" },
  { name: "Referenzen", url: "/referenzen/" },
]);
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/referenzen/"
  noindex={false}
  schema={schema}
>
  <Breadcrumb crumbs={[{ label: "Start", href: "/" }, { label: "Referenzen" }]} />

  <section class="border-b border-[var(--color-border)] pt-22 pb-10">
    <div class="container-content">
      <div class="mb-4 text-xs uppercase tracking-[0.16em] text-[var(--color-accent)]">
        Referenzen · ausgewählte Projekte
      </div>
      <h1 class="mb-5 max-w-[800px] text-[clamp(36px,5.5vw,64px)] font-bold tracking-[-0.04em] leading-[1.05]">
        <span class="text-gradient-light">Mehr als nur schöne</span>
        <span class="text-gradient-accent">Websites.</span>
      </h1>
      <p class="max-w-[640px] text-lg text-[var(--color-text-muted)]">
        Eine Auswahl aus 18 Jahren Webdesign. Von Onlineshops auf WooCommerce,
        Shopware und Oxid über Vereinswebseiten bis zu KI-gestützten
        Vertriebs-Tools.
      </p>
    </div>
  </section>

  {/* Filter-Bar — sticky, damit beim Scrollen erreichbar */}
  <section class="sticky top-16 z-40 border-b border-[var(--color-border)] bg-[rgba(10,10,10,0.85)] py-5 backdrop-blur-xl">
    <div class="container-content">
      <div class="flex flex-wrap justify-center gap-2" id="filter-bar">
        <button class="pill active" data-filter="alle">
          Alle <span class="count">{counts.alle}</span>
        </button>
        <button class="pill" data-filter="websites">
          Webseiten <span class="count">{counts.websites}</span>
        </button>
        <button class="pill" data-filter="onlineshops">
          Onlineshops <span class="count">{counts.onlineshops}</span>
        </button>
      </div>
    </div>
  </section>

  <section class="py-14 pb-24">
    <div class="container-content max-w-[1280px]">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3" id="ref-grid">
        {references.map((ref) => (
          <MonitorCard
            url={ref.domain}
            image={ref.image}
            alt={`${ref.title} — ${ref.meta} (${ref.category === "onlineshops" ? "Onlineshop" : "Webseite"})`}
            href={ref.featured ? `/referenzen/${ref.slug}/` : undefined}
            variant="default"
          >
            <div data-cat={ref.category}>
              <div class="mb-2 flex items-center gap-2.5">
                <span class:list={["info-cat", ref.category]}>
                  <span class="dot"></span>
                  {ref.category === "onlineshops" ? "Onlineshop" : "Webseite"}
                </span>
                <span class="ml-auto text-xs text-[var(--color-text-faint)]">
                  {ref.date}
                </span>
              </div>
              <div class="text-[18px] font-semibold leading-[1.3] tracking-[-0.01em]">
                {ref.title}
              </div>
              <div class="mt-1.5 flex items-center justify-between gap-2">
                <span class="text-[13px] text-[var(--color-text-muted)]">
                  {ref.meta}
                </span>
                {ref.liveUrl && (
                  <a
                    href={ref.liveUrl}
                    target="_blank"
                    rel="noopener"
                    class="live-badge"
                    aria-label={`${ref.title} live ansehen (öffnet in neuem Tab)`}
                  >
                    Live ansehen
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                      <path d="M7 17 17 7M9 7h8v8" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          </MonitorCard>
        ))}
        <div class="no-results hidden col-span-full py-20 text-center text-[var(--color-text-muted)]" id="no-results">
          Keine Projekte in dieser Kategorie.
        </div>
      </div>

      <div class="mt-20 rounded-[20px] border border-[var(--color-border)] p-14 text-center" style="background: linear-gradient(135deg, rgba(255,107,53,0.07) 0%, rgba(45,212,191,0.04) 100%);">
        <h3 class="mb-3 text-[28px] font-bold tracking-[-0.02em]">
          Soll dein Projekt das nächste sein?
        </h3>
        <p class="mx-auto mb-7 max-w-[520px] text-[var(--color-text-muted)]">
          30 Minuten Erstgespräch, kostenlos und unverbindlich. Wir schauen
          gemeinsam, ob und wie wir dein Vorhaben am besten umsetzen können.
        </p>
        <a
          href="/kontakt/"
          class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-[15px] font-medium text-black transition-transform hover:-translate-y-px"
        >
          Erstgespräch vereinbaren
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 9px 18px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    background: transparent;
    cursor: pointer;
    transition: all 0.18s;
    font-family: inherit;
  }
  .pill:hover {
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }
  .pill.active {
    background: var(--color-text);
    color: #000;
    border-color: var(--color-text);
  }
  .pill .count {
    font-size: 12px;
    background: rgba(255, 255, 255, 0.08);
    padding: 2px 8px;
    border-radius: 999px;
    color: var(--color-text-faint);
  }
  .pill.active .count {
    background: rgba(0, 0, 0, 0.1);
    color: rgba(0, 0, 0, 0.6);
  }

  .info-cat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
  }
  .info-cat .dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }
  .info-cat.onlineshops .dot {
    background: var(--color-teal);
  }

  .live-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.01em;
    white-space: nowrap;
    color: var(--color-accent);
    background: rgba(255, 107, 53, 0.1);
    border: 1px solid rgba(255, 107, 53, 0.25);
    transition: all 0.16s;
  }
  .live-badge:hover {
    color: #fff;
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }
  .live-badge svg {
    transition: transform 0.16s;
  }
  .live-badge:hover svg {
    transform: translate(1px, -1px);
  }

  .monitor-card.is-hidden {
    display: none;
  }
  .no-results.show {
    display: block;
  }
</style>

<script>
  // Filter-Logik: Klick auf Pill → Karten ein-/ausblenden basierend auf data-cat
  const pills = document.querySelectorAll<HTMLButtonElement>("#filter-bar .pill");
  const cards = document.querySelectorAll<HTMLAnchorElement>("#ref-grid .monitor-card");
  const noResults = document.getElementById("no-results");

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      const filter = pill.dataset.filter;
      if (!filter) return;

      pills.forEach((p) => p.classList.remove("active"));
      pill.classList.add("active");

      let visibleCount = 0;
      cards.forEach((card) => {
        // data-cat liegt auf dem inneren Container in der MonitorCard
        const inner = card.querySelector<HTMLElement>("[data-cat]");
        const cat = inner?.dataset.cat;
        const shouldShow = filter === "alle" || cat === filter;
        card.classList.toggle("is-hidden", !shouldShow);
        if (shouldShow) visibleCount++;
      });

      noResults?.classList.toggle("show", visibleCount === 0);
      noResults?.classList.toggle("hidden", visibleCount !== 0);
    });
  });
</script>
