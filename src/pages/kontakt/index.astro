---
/**
 * /kontakt/ — Kontaktseite mit Formular + NAP-Block + alternativen Wegen.
 *
 * Formular postet an /neu/kontakt.php (siehe public/kontakt.php).
 * Nach Submit redirected der PHP-Endpoint zurück hierher mit ?status=ok|error|invalid.
 *
 * Drei mögliche Zustände werden serverseitig nicht erkannt (Astro-Build ist statisch),
 * deshalb wird der ?status-Parameter clientseitig per JS ausgelesen und das passende
 * Banner eingeblendet. Funktioniert auch ohne JS — die Banner sind im HTML enthalten
 * und werden nur via :target / hash o. URL-Param sichtbar gemacht.
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { site } from "../../data/site";
import { breadcrumbSchema, localBusinessSchema } from "../../lib/schema";

const title = "Kontakt — 2FOX4 Websites and more, Sachsenhagen";
const description =
  "Direkter Draht zur Webagentur 2FOX4: Telefon 05725 9890175, info@2fox4.de oder Kontaktformular. Sachsenhagen, Niedersachsen.";

const schema = [
  breadcrumbSchema([
    { name: "Start", url: "/" },
    { name: "Kontakt", url: "/kontakt/" },
  ]),
  localBusinessSchema({
    description:
      "Webdesign-Agentur in Sachsenhagen für Stadthagen, Bückeburg, Wunstorf und die gesamte Region Schaumburg/Hannover.",
  }),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/kontakt/"
  noindex={false}
  schema={schema}
>
  <Breadcrumb crumbs={[{ label: "Start", href: "/" }, { label: "Kontakt" }]} />

  {/* ====================  Hero ==================== */}
  <section class="relative overflow-hidden border-b border-[var(--color-border)] pt-20 pb-12">
    <div class="hero-grid-bg"></div>
    <div class="container-content relative z-10">
      <div class="mb-4 text-xs uppercase tracking-[0.16em] text-[var(--color-accent)]">
        Kontakt · Wir freuen uns auf dich
      </div>
      <h1 class="mb-5 max-w-[820px] text-[clamp(36px,5.5vw,60px)] font-bold tracking-[-0.04em] leading-[1.05]">
        <span class="text-gradient-light">Lass uns</span>
        <span class="text-gradient-accent">reden.</span>
      </h1>
      <p class="max-w-[680px] text-lg leading-[1.65] text-[var(--color-text-muted)]">
        Egal ob neue Website, Relaunch, SEO oder einfach erst mal ein Gespräch
        ohne Verpflichtung — wir antworten in der Regel innerhalb eines
        Werktages. Wähle einfach den Kanal, der dir am liebsten ist.
      </p>
    </div>
  </section>

  {/* ====================  Statusbanner ==================== */}
  <div class="container-content mt-10" data-status-banner-wrap>
    <div
      id="status-ok"
      class="status-banner status-banner--ok"
      role="status"
      hidden
    >
      <strong>Danke!</strong> Deine Nachricht ist bei uns angekommen. Wir
      melden uns in der Regel innerhalb eines Werktages.
    </div>
    <div
      id="status-error"
      class="status-banner status-banner--error"
      role="alert"
      hidden
    >
      <strong>Das hat leider nicht geklappt.</strong> Bitte schick uns deine
      Nachricht direkt an
      <a href={site.nap.emailHref}>{site.nap.email}</a> — wir lesen sie
      garantiert.
    </div>
    <div
      id="status-invalid"
      class="status-banner status-banner--error"
      role="alert"
      hidden
    >
      <strong>Bitte fülle die markierten Felder aus.</strong> Name, E-Mail und
      Nachricht sind Pflicht, und die Datenschutz-Bestätigung muss gesetzt sein.
    </div>
  </div>

  {/* ====================  Hauptbereich: 2 Spalten ==================== */}
  <section class="py-12 pb-20">
    <div class="container-content">
      <div class="grid gap-12 lg:grid-cols-[1fr_1.2fr] items-start">
        {/* ----------  Linke Spalte: Kontaktinfos ---------- */}
        <div>
          <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-8">
            <h2 class="mb-2 text-[24px] font-bold tracking-[-0.02em]">
              Direkt anrufen oder schreiben
            </h2>
            <p class="mb-7 text-[15px] text-[var(--color-text-muted)]">
              Schneller geht's nicht. Wir gehen am Telefon ran zwischen Mo–Fr
              von 9 bis 18 Uhr.
            </p>

            <a
              href={site.nap.phoneHref}
              class="flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-black/20 p-4 mb-3 transition-all hover:border-[var(--color-border-strong)] hover:-translate-y-0.5"
            >
              <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                </svg>
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                  Telefon
                </div>
                <div class="text-[17px] font-semibold">
                  {site.nap.phoneDisplay}
                </div>
              </div>
            </a>

            <a
              href={site.nap.emailHref}
              class="flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-black/20 p-4 mb-3 transition-all hover:border-[var(--color-border-strong)] hover:-translate-y-0.5"
            >
              <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                  <polyline points="22,6 12,13 2,6" />
                </svg>
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                  E-Mail
                </div>
                <div class="text-[17px] font-semibold">
                  {site.nap.email}
                </div>
              </div>
            </a>

            <div class="flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-black/20 p-4 mb-3">
              <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                  <circle cx="12" cy="10" r="3" />
                </svg>
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                  Adresse
                </div>
                <div class="text-[15px] leading-[1.5]">
                  {site.nap.company}<br />
                  {site.nap.street}, {site.nap.zip} {site.nap.city}
                </div>
              </div>
            </div>

            <div class="flex items-center gap-4 rounded-xl border border-[var(--color-border)] bg-black/20 p-4">
              <span class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-5 w-5">
                  <circle cx="12" cy="12" r="10" />
                  <polyline points="12 6 12 12 16 14" />
                </svg>
              </span>
              <div>
                <div class="text-[11px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
                  Öffnungszeiten
                </div>
                <div class="text-[15px]">Mo–Fr · 9 – 18 Uhr</div>
              </div>
            </div>
          </div>

          <p class="mt-5 text-[13px] text-[var(--color-text-faint)] leading-[1.6]">
            Du erreichst uns persönlich aus dem Schaumburger Land — vor-Ort-Termine
            für Stadthagen, Bückeburg, Wunstorf und Region sind selbstverständlich
            möglich.
          </p>
        </div>

        {/* ----------  Rechte Spalte: Formular ---------- */}
        <div>
          <form
            method="POST"
            action="/kontakt.php"
            class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-8"
            novalidate
          >
            <h2 class="mb-2 text-[24px] font-bold tracking-[-0.02em]">
              Nachricht hinterlassen
            </h2>
            <p class="mb-7 text-[15px] text-[var(--color-text-muted)]">
              Beschreib uns kurz dein Anliegen — wir melden uns spätestens am
              nächsten Werktag.
            </p>

            {/*
              Anti-Spam-Felder — alle visuell ausgeblendet, aber für Bots
              befüllbar. Server prüft im kontakt.php und verwirft die Mail
              still, wenn eines befüllt ist oder die Submit-Zeit zu schnell.
            */}
            <div aria-hidden="true" class="honeypot">
              <label for="contact-fax">Fax-Nummer (bitte leer lassen)</label>
              <input
                type="text"
                id="contact-fax"
                name="fax_number"
                tabindex="-1"
                autocomplete="off"
              />
              <label for="contact-url">URL (bitte leer lassen)</label>
              <input
                type="text"
                id="contact-url"
                name="company_url"
                tabindex="-1"
                autocomplete="off"
              />
            </div>
            {/* Time-Trap: per JS beim Mount auf Date.now() gesetzt */}
            <input type="hidden" name="form_loaded_at" value="" data-form-loaded-at />

            <div class="form-grid">
              <div class="form-field">
                <label for="contact-name">
                  Name <span class="required">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  autocomplete="name"
                  minlength="2"
                  maxlength="100"
                />
              </div>

              <div class="form-field">
                <label for="contact-email">
                  E-Mail <span class="required">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  autocomplete="email"
                  maxlength="200"
                />
              </div>

              <div class="form-field">
                <label for="contact-phone">
                  Telefon <span class="hint">(optional)</span>
                </label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  autocomplete="tel"
                  maxlength="50"
                />
              </div>

              <div class="form-field">
                <label for="contact-web">
                  Aktuelle Onlinepräsenz <span class="hint">(optional)</span>
                </label>
                <input
                  type="url"
                  id="contact-web"
                  name="web_presence"
                  placeholder="https://"
                  maxlength="200"
                />
              </div>
            </div>

            <div class="form-field mt-5">
              <label for="contact-message">
                Mitteilung <span class="required">*</span>
              </label>
              <textarea
                id="contact-message"
                name="message"
                required
                rows="6"
                minlength="5"
                maxlength="5000"
                placeholder="Worum geht's? Idee, Frage, Wunschtermin …"
              ></textarea>
            </div>

            <label class="consent mt-5">
              <input type="checkbox" name="consent" value="yes" required />
              <span>
                Ich habe die
                <a href="/datenschutz/" data-legal="datenschutz">Datenschutzerklärung</a>
                gelesen und stimme der Verarbeitung meiner Daten zum Zweck der
                Kontaktaufnahme zu. Mir ist bekannt, dass ich diese Einwilligung
                jederzeit widerrufen kann.<span class="required"> *</span>
              </span>
            </label>

            <button type="submit" class="submit-btn mt-7">
              Nachricht absenden
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </button>

            <p class="mt-4 text-[12px] text-[var(--color-text-faint)] leading-[1.6]">
              Mit <span class="required">*</span> markierte Felder sind
              Pflichtangaben.
            </p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ==========  Status-Banner  ========== */
  .status-banner {
    padding: 14px 20px;
    border-radius: 12px;
    font-size: 14.5px;
    line-height: 1.55;
    border: 1px solid var(--color-border-strong);
  }
  .status-banner strong {
    color: var(--color-text);
    font-weight: 600;
  }
  .status-banner--ok {
    background: rgba(45, 212, 191, 0.08);
    border-color: rgba(45, 212, 191, 0.3);
    color: #c0f4ec;
  }
  .status-banner--error {
    background: rgba(255, 107, 53, 0.08);
    border-color: rgba(255, 107, 53, 0.3);
    color: #ffd5c0;
  }
  .status-banner a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ==========  Honeypot (visuell weg, für Bots da)  ========== */
  .honeypot {
    position: absolute;
    left: -10000px;
    top: -10000px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  /* ==========  Formular  ========== */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px 14px;
  }
  @media (max-width: 640px) {
    .form-grid {
      grid-template-columns: 1fr;
    }
  }
  .form-field {
    display: flex;
    flex-direction: column;
  }
  .form-field label,
  .consent > span {
    font-size: 13px;
    color: var(--color-text);
    margin-bottom: 6px;
    font-weight: 500;
  }
  .form-field label .required {
    color: var(--color-accent);
  }
  .form-field label .hint {
    color: var(--color-text-faint);
    font-weight: 400;
    font-size: 12px;
    margin-left: 2px;
  }

  .form-field input,
  .form-field textarea {
    width: 100%;
    padding: 11px 14px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    color: var(--color-text);
    font-size: 15px;
    font-family: inherit;
    line-height: 1.5;
    transition: border-color 0.15s, background-color 0.15s, box-shadow 0.15s;
  }
  .form-field input:hover,
  .form-field textarea:hover {
    border-color: var(--color-border-strong);
  }
  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    background: rgba(0, 0, 0, 0.4);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.12);
  }
  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--color-text-faint);
  }

  /* Server-Side-Hervorhebung über data-error */
  .form-field.has-error input,
  .form-field.has-error textarea {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.12);
  }
  .form-field.has-error label .required {
    color: var(--color-accent);
  }

  /* Fehler-Markierung der Datenschutz-Checkbox */
  .consent.has-error {
    background: rgba(255, 107, 53, 0.08);
    border-radius: 8px;
    padding: 10px 12px;
    margin: -10px -12px 0;
    box-shadow: 0 0 0 1px rgba(255, 107, 53, 0.3);
  }
  .consent.has-error > span strong {
    color: var(--color-accent);
  }

  /* ==========  Consent  ========== */
  .consent {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    cursor: pointer;
  }
  .consent input[type="checkbox"] {
    margin-top: 3px;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    accent-color: var(--color-accent);
    cursor: pointer;
  }
  .consent > span {
    margin-bottom: 0;
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    font-weight: 400;
  }
  .consent a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ==========  Submit-Button  ========== */
  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-text);
    color: #000;
    border: none;
    padding: 13px 24px;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .submit-btn:hover {
    transform: translateY(-1px);
    background: #fff;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
  }
</style>

<script>
  // ---------- 1) Status-Banner einblenden, je nach ?status= ----------
  // (Fallback für Submits mit JS-aus — Server-seitig validiert und redirected)
  const params = new URLSearchParams(window.location.search);
  const status = params.get("status");
  if (status === "ok") {
    document.getElementById("status-ok")?.removeAttribute("hidden");
  } else if (status === "error") {
    document.getElementById("status-error")?.removeAttribute("hidden");
  } else if (status === "invalid") {
    document.getElementById("status-invalid")?.removeAttribute("hidden");
    const fields = (params.get("fields") || "").split(",").filter(Boolean);
    fields.forEach((name) => {
      const input = document.querySelector(`[name="${name}"]`);
      if (input?.getAttribute("type") === "checkbox") {
        input.closest(".consent")?.classList.add("has-error");
      } else {
        input?.closest(".form-field")?.classList.add("has-error");
      }
    });
  }
  if (status) {
    document
      .querySelector("[data-status-banner-wrap]")
      ?.scrollIntoView({ behavior: "smooth", block: "center" });
  }

  // ---------- 2) Time-Trap: Page-Load-Zeitpunkt ins Hidden-Feld ----------
  // Server lehnt das Formular ab, wenn der Submit unter 3 Sekunden nach
  // dem Page-Load passiert (= klassisches Bot-Muster).
  const loadedAtField = document.querySelector<HTMLInputElement>(
    '[data-form-loaded-at]'
  );
  if (loadedAtField) {
    loadedAtField.value = String(Date.now());
  }

  // ---------- 3) Client-seitige Validation VOR dem Submit ----------
  // Damit das Formular bei Fehler NICHT geschickt wird (und kein Reload
  // alle Felder leert). Der Server prüft trotzdem nochmal — Defense in depth.
  const form = document.querySelector<HTMLFormElement>('form[action$="kontakt.php"]');
  if (form) {
    form.addEventListener("submit", (e) => {
      // Vorherige Fehler-Markierungen entfernen
      document.querySelectorAll<HTMLElement>(".form-field.has-error, .consent.has-error")
        .forEach((el) => el.classList.remove("has-error"));
      ["status-ok", "status-error", "status-invalid"].forEach((id) => {
        document.getElementById(id)?.setAttribute("hidden", "");
      });

      const errors: HTMLElement[] = [];

      const get = (name: string) =>
        form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${name}"]`);

      const nameField = get("name");
      if (!nameField || nameField.value.trim().length < 2) {
        if (nameField) errors.push(nameField);
      }

      const emailField = get("email");
      const emailOk = emailField && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailField.value.trim());
      if (emailField && !emailOk) errors.push(emailField);

      const messageField = get("message");
      if (!messageField || messageField.value.trim().length < 5) {
        if (messageField) errors.push(messageField);
      }

      const consentField = get("consent") as HTMLInputElement | null;
      if (!consentField || !consentField.checked) {
        if (consentField) errors.push(consentField);
      }

      if (errors.length === 0) return; // Alles ok → Submit darf raus

      // Fehler — Submit blockieren, Felder markieren, Banner zeigen
      e.preventDefault();
      errors.forEach((input) => {
        if ((input as HTMLInputElement).type === "checkbox") {
          input.closest(".consent")?.classList.add("has-error");
        } else {
          input.closest(".form-field")?.classList.add("has-error");
        }
      });
      const invalid = document.getElementById("status-invalid");
      invalid?.removeAttribute("hidden");
      document
        .querySelector("[data-status-banner-wrap]")
        ?.scrollIntoView({ behavior: "smooth", block: "center" });
      // Focus aufs erste Fehlerfeld (nach kurzem Delay, sodass Scroll fertig ist)
      setTimeout(() => errors[0]?.focus({ preventScroll: false }), 350);
    });

    // Beim Tippen / Anhaken: Fehler-Markierung der jeweiligen Sektion entfernen
    form.querySelectorAll<HTMLElement>('input, textarea').forEach((input) => {
      input.addEventListener("input", () => {
        input.closest(".form-field")?.classList.remove("has-error");
        input.closest(".consent")?.classList.remove("has-error");
      });
      input.addEventListener("change", () => {
        input.closest(".consent")?.classList.remove("has-error");
      });
    });
  }
</script>
