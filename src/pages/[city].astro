---
/**
 * Dynamische Route: erzeugt aus `cities.ts` alle Stadt-Landingpages.
 * Slug = URL-Pfad, z. B. /webdesign-stadthagen/, /webdesign-bueckeburg/ etc.
 *
 * Astro nimmt im `getStaticPaths()` jede City und generiert daraus zur
 * Build-Zeit eine eigene HTML-Datei.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import CityHero from "../components/CityHero.astro";
import LocalRefs from "../components/LocalRefs.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import CityServices from "../components/CityServices.astro";
import FAQ from "../components/FAQ.astro";
import NAPSection from "../components/NAPSection.astro";
import CTASection from "../components/CTASection.astro";
import { cities, faqFor, type City } from "../data/cities";
import { localBusinessSchema, faqSchema, breadcrumbSchema } from "../lib/schema";
import { site } from "../data/site";

export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;
const faqItems = faqFor(city);

// Quick-Trust-Leiste für den Hero (Distanz, Erfahrung, Termine, Refs)
const quickTrust = [
  {
    iconSvg: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>`,
    text: `<strong>${city.distance.km} km</strong> bis ${city.name}`,
  },
  {
    iconSvg: `<rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/>`,
    text: `<strong>18 Jahre</strong> Erfahrung`,
  },
  {
    iconSvg: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
    text: `Persönliche <strong>Vor-Ort-Termine</strong>`,
  },
  {
    iconSvg: `<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>`,
    text:
      city.localRefs && city.localRefs.length > 0
        ? `Lokale <strong>Referenzen</strong>`
        : `<strong>125+</strong> Projekte`,
  },
];

// Stadt-spezifisches "Warum"-Block: erste Karte wird personalisiert
const reasons = [
  {
    iconSvg: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    title: "Wir sind in der Region",
    text: `Sitz in Sachsenhagen, ${city.distance.km} km von ${city.name} entfernt. Vor-Ort-Termine sind kein Problem — auch kurzfristig. Du redest mit echten Menschen, nicht mit einem Kundenservice-System.`,
  },
  {
    iconSvg: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
    title: "18 Jahre Praxis-Erfahrung",
    text: "Seit 2008 bauen wir Websites — von WordPress-Visitenkarten über WooCommerce- und Shopware-Shops bis zu KI-Tools. Über 125 Projekte aus allen Branchen.",
  },
  {
    iconSvg: `<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>`,
    title: "Eigene WordPress-Plugins",
    text: "Wir entwickeln selbst Plugins, die wir im offiziellen WordPress-Repository veröffentlichen. Du bekommst keine Standard-Lösung, sondern Werkzeuge, die wir selbst gebaut und verstanden haben.",
  },
];

// SEO Meta
const title = `Webdesigner ${city.name} — 2FOX4 aus Sachsenhagen, ${city.distance.km} km entfernt`;
const description = `Webdesign für ${city.name}: WordPress, SEO, Onlineshops. 2FOX4 aus Sachsenhagen ist Ihre Webagentur in der Region. Persönlich, regional, seit 2008.`;

// JSON-LD Bundle: LocalBusiness + Breadcrumb + FAQPage
const schema = [
  localBusinessSchema({
    description: `Webdesign-Agentur mit Sitz in Sachsenhagen für Unternehmen in ${city.name} und der Region.`,
    image: city.localRefs?.[0]?.image,
  }),
  breadcrumbSchema([
    { name: "Start", url: "/" },
    { name: "Regional", url: "/regional/" },
    { name: `Webdesigner ${city.name}`, url: `/${city.slug}/` },
  ]),
  faqSchema(faqItems),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={`/${city.slug}/`}
  noindex={false}
  schema={schema}
>
  <Breadcrumb
    crumbs={[
      { label: "Start", href: "/" },
      { label: "Regional", href: "/regional/" },
      { label: city.name },
    ]}
  />

  <CityHero
    eyebrow={city.heroEyebrow}
    titleLine1={city.heroTitleLine1}
    titleLine2={city.heroTitleLine2}
    sub={city.heroSub}
    quickTrust={quickTrust}
  />

  {city.localRefs && city.localRefs.length > 0 && (
    <LocalRefs city={city.name} refs={city.localRefs} />
  )}

  <WhyChooseUs
    title={`Drei Gründe, einen Webdesigner aus der Region statt einer Konzern-Agentur zu wählen.`}
    sub={`Anonyme Konzern-Agenturen versprechen viel und liefern Templates. Eine regionale Agentur kennt ${city.name} und die Menschen, die hier leben und kaufen.`}
    reasons={reasons}
  />

  <CityServices city={city.name} />

  <FAQ
    items={faqItems}
    title={`Was ${city.inhabitantAdjective} Unternehmer wissen wollen.`}
  />

  <NAPSection
    distance={{
      km: city.distance.km,
      note: city.distance.note,
      city: city.name,
    }}
  />

  <CTASection
    title={`Bereit für eine neue Website?`}
    text={`30 Minuten kostenloses Erstgespräch. Wir schauen uns deine aktuelle Situation an und zeigen dir ehrlich, wo der größte Hebel liegt.`}
  />
</BaseLayout>
