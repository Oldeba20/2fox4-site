---
/**
 * 404 — "Ups, verlaufen!"
 *
 * Statt einer langweiligen Fehlerseite zeigen wir einen kleinen
 * Pseudo-3D-Ego-Shooter im Doom/Wolfenstein-Stil. Raycasting-Renderer,
 * Pointer-Lock-Maus, WASD-Bewegung.
 *
 * Hinweise:
 * - noindex/nofollow, damit die Seite nicht im Suchindex landet
 * - Apache (Kasserver) liefert /404.html bei nicht gefundenen URLs aus
 *   (ErrorDocument 404 /404.html ist bereits in der Server-.htaccess).
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Ups, verlaufen! — 2fox4";
const description =
  "Die gesuchte Seite gibt es nicht — aber dafür ein kleines Spiel zum Zeitvertreib. Schieß dich raus aus der Bug-Hölle.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="lost-page">
    <header class="lost-hero">
      <p class="lost-tag">Fehler 404</p>
      <h1 class="lost-title">Ups, verlaufen!</h1>
      <p class="lost-quote" id="lost-quote">
        Diese URL existiert nicht. Aber die Monster schon.
      </p>
      <p class="lost-hint">
        <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> zum Laufen ·
        Maus zum Umsehen · <kbd>Klick</kbd> zum Schießen ·
        <kbd>ESC</kbd> zum Pause-machen
      </p>
      <div class="lost-actions">
        <a class="btn btn-primary" href="/">← Zurück zur Startseite</a>
        <a class="btn btn-ghost" href="/kontakt/">Lieber direkt schreiben</a>
      </div>
    </header>

    <div class="game-wrapper">
      <div class="game-frame" id="game-frame">
        <canvas id="fps-canvas" width="480" height="300"></canvas>

        <!-- HUD-Overlay (HP, Ammo, Score, Welle) -->
        <div class="hud" aria-live="polite">
          <div class="hud-row hud-top">
            <div class="hud-chip">
              <span class="hud-label">Welle</span>
              <span class="hud-value" id="hud-wave">1</span>
            </div>
            <div class="hud-chip">
              <span class="hud-label">Kills</span>
              <span class="hud-value" id="hud-kills">0</span>
            </div>
            <div class="hud-chip">
              <span class="hud-label">Zeit</span>
              <span class="hud-value" id="hud-time">0:00</span>
            </div>
          </div>
          <div class="hud-bottom">
            <div class="hud-stat hud-stat-hp">
              <div class="hud-stat-label">HP</div>
              <div class="hud-bar">
                <div class="hud-bar-fill" id="hud-hp-fill"></div>
              </div>
              <div class="hud-stat-num" id="hud-hp">100</div>
            </div>
            <div class="hud-stat hud-stat-ammo">
              <div class="hud-stat-label">AMMO</div>
              <div class="hud-stat-num hud-stat-num-lg" id="hud-ammo">30 / ∞</div>
            </div>
          </div>
        </div>

        <!-- Crosshair -->
        <div class="crosshair" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
        </div>

        <!-- Start-Overlay -->
        <div class="overlay" id="overlay-start">
          <div class="overlay-card">
            <h2>🔫 Eintreten in die Bug-Hölle?</h2>
            <p class="overlay-sub">
              Überlebe so lange wie möglich. Die Bugs werden mehr, größer
              und schneller. Du hast nur dich, dein Gewehr und unendlich
              Magazine.
            </p>
            <ul class="overlay-list">
              <li><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> — laufen</li>
              <li>Maus — umsehen</li>
              <li>Klick — schießen</li>
              <li><kbd>R</kbd> — nachladen · <kbd>ESC</kbd> — Pause</li>
            </ul>
            <button class="btn btn-primary btn-lg" id="btn-start" type="button">
              ▶︎ Klick = Start (Pointer-Lock)
            </button>
            <p class="overlay-note">
              Maus wird gesperrt. Mit <kbd>ESC</kbd> wieder freigeben.
            </p>
          </div>
        </div>

        <!-- Pause-Overlay -->
        <div class="overlay overlay-pause" id="overlay-pause" hidden>
          <div class="overlay-card">
            <h2>⏸ Pause</h2>
            <p>Klick zurück ins Spielfeld, weiter geht's.</p>
            <button class="btn btn-primary" id="btn-resume" type="button">
              ▶︎ Weiterspielen
            </button>
          </div>
        </div>

        <!-- Game-Over-Overlay -->
        <div class="overlay overlay-gameover" id="overlay-gameover" hidden>
          <div class="overlay-card">
            <h2>💀 Game Over</h2>
            <p class="overlay-stat">
              Du hast <strong id="go-time">0:00</strong> überlebt,
              <strong id="go-kills">0</strong> Bugs erledigt
              und Welle <strong id="go-wave">1</strong> erreicht.
            </p>
            <p class="overlay-line" id="go-line">
              Die Bugs feiern. Wahrscheinlich.
            </p>
            <div class="overlay-actions">
              <button class="btn btn-primary" id="btn-restart" type="button">
                ↻ Nochmal
              </button>
              <a class="btn btn-ghost" href="/">Zurück zur Startseite</a>
            </div>
          </div>
        </div>

        <!-- Mobile-Hinweis -->
        <div class="mobile-note" id="mobile-note" hidden>
          <p>📱 Auf dem Handy nicht spielbar — komm gerne mit Maus + Tastatur wieder.</p>
          <a href="/" class="btn btn-primary">← Zur Startseite</a>
        </div>
      </div>

      <p class="game-credits">
        Klick rein zum Starten, <kbd>ESC</kbd> zum Pausieren. Falls du
        eigentlich was ganz anderes wolltest —
        <a href="/kontakt/">hier geht's zum Kontakt</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .lost-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2.5rem 1.25rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .lost-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    align-items: center;
  }
  .lost-tag {
    font-family: "JetBrains Mono Variable", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #9ca3af;
    margin: 0;
  }
  .lost-title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }
  .lost-quote {
    font-size: 1.1rem;
    color: #6b7280;
    margin: 0;
    max-width: 36rem;
  }
  .lost-hint {
    font-size: 0.85rem;
    color: #6b7280;
    margin: 0;
    max-width: 40rem;
  }
  kbd {
    font-family: "JetBrains Mono Variable", monospace;
    background: #f3f4f6;
    border: 1px solid #d1d5db;
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 1px 6px;
    margin: 0 2px;
    font-size: 0.82em;
  }
  .lost-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.1rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    transition: transform 0.1s ease, background 0.15s ease;
    font-family: inherit;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-primary { background: #b91c1c; color: #fff; }
  .btn-primary:hover { background: #991b1b; }
  .btn-ghost {
    background: transparent;
    color: #111827;
    border-color: #d1d5db;
  }
  .btn-ghost:hover { background: #f3f4f6; }
  .btn-lg { padding: 0.85rem 1.4rem; font-size: 1.05rem; }

  /* --- Game frame --- */
  .game-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    width: 100%;
  }
  .game-frame {
    position: relative;
    width: 100%;
    max-width: 900px;
    aspect-ratio: 8 / 5;
    background: #0a0a0a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 25px 60px -20px rgba(0,0,0,0.6),
                inset 0 0 0 1px rgba(255,255,255,0.05);
    cursor: crosshair;
    user-select: none;
  }
  #fps-canvas {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    background: #000;
  }

  /* Crosshair */
  .crosshair {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 18px;
    margin: -9px 0 0 -9px;
    pointer-events: none;
    z-index: 3;
  }
  .crosshair span {
    position: absolute;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 0 4px rgba(0,0,0,0.7);
  }
  .crosshair span:nth-child(1) { left: 50%; top: 0;    width: 2px; height: 6px; margin-left: -1px; }
  .crosshair span:nth-child(2) { left: 50%; bottom: 0; width: 2px; height: 6px; margin-left: -1px; }
  .crosshair span:nth-child(3) { top: 50%; left: 0;    height: 2px; width: 6px; margin-top: -1px; }
  .crosshair span:nth-child(4) { top: 50%; right: 0;   height: 2px; width: 6px; margin-top: -1px; }

  /* HUD */
  .hud {
    position: absolute;
    inset: 0;
    pointer-events: none;
    color: #fef3c7;
    font-family: "JetBrains Mono Variable", monospace;
    z-index: 2;
  }
  .hud-row {
    position: absolute;
    top: 12px;
    left: 12px;
    right: 12px;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .hud-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(252, 211, 77, 0.3);
    border-radius: 4px;
    padding: 0.25rem 0.6rem;
    font-size: 0.78rem;
  }
  .hud-label {
    text-transform: uppercase;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    opacity: 0.65;
  }
  .hud-value { font-weight: 700; font-size: 0.95rem; color: #fbbf24; }

  .hud-bottom {
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 12px;
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    justify-content: space-between;
  }
  .hud-stat { display: flex; flex-direction: column; gap: 0.25rem; min-width: 140px; }
  .hud-stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    opacity: 0.6;
    text-transform: uppercase;
  }
  .hud-stat-num {
    font-size: 1.05rem;
    font-weight: 800;
    color: #fbbf24;
    text-shadow: 0 0 6px rgba(251, 191, 36, 0.3);
  }
  .hud-stat-num-lg { font-size: 1.4rem; }
  .hud-stat-ammo { text-align: right; }
  .hud-bar {
    height: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(252, 211, 77, 0.25);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .hud-bar-fill {
    position: absolute;
    inset: 0;
    width: 100%;
    transform-origin: left center;
    background: linear-gradient(90deg, #dc2626, #f97316, #fbbf24);
    transition: transform 0.2s ease;
  }

  /* Overlays */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(8, 6, 6, 0.85);
    backdrop-filter: blur(4px);
    color: #fef3c7;
    z-index: 10;
    padding: 1rem;
  }
  .overlay[hidden] { display: none; }
  .overlay-card {
    background: #1c1917;
    border: 1px solid rgba(252, 211, 77, 0.2);
    border-radius: 8px;
    padding: 1.4rem 1.6rem;
    max-width: 28rem;
    width: 100%;
    text-align: center;
    box-shadow: 0 25px 50px -12px rgba(0,0,0,0.7);
  }
  .overlay-card h2 { margin: 0 0 0.4rem; font-size: 1.3rem; color: #fbbf24; }
  .overlay-sub { color: #d6d3d1; margin: 0 0 0.75rem; font-size: 0.9rem; }
  .overlay-list {
    text-align: left;
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    color: #d6d3d1;
    font-size: 0.85rem;
    display: grid;
    gap: 0.25rem;
  }
  .overlay-list kbd {
    background: #292524;
    border-color: #44403c;
    color: #fef3c7;
  }
  .overlay-note {
    font-size: 0.75rem;
    color: #a8a29e;
    margin: 0.6rem 0 0;
  }
  .overlay-stat strong { color: #fbbf24; }
  .overlay-line { font-style: italic; color: #a8a29e; }
  .overlay-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.75rem;
  }

  .mobile-note {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    background: rgba(8, 6, 6, 0.95);
    color: #fef3c7;
    text-align: center;
    padding: 1.5rem;
    z-index: 20;
  }
  .mobile-note[hidden] { display: none; }
  .mobile-note p { margin: 0; max-width: 22rem; }

  .game-credits {
    font-size: 0.85rem;
    color: #6b7280;
    text-align: center;
    margin: 0;
  }
  .game-credits a { color: #b91c1c; font-weight: 600; }
  .game-credits kbd { padding: 0 5px; font-size: 0.78em; }

  @media (max-width: 640px) {
    .lost-page { padding-top: 1.5rem; }
    .hud-stat { min-width: 100px; }
    .hud-stat-num-lg { font-size: 1.1rem; }
  }
</style>

<script is:inline>
  (function () {
    "use strict";

    const canvas = document.getElementById("fps-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    ctx.imageSmoothingEnabled = false;

    const W = canvas.width;   // 480
    const H = canvas.height;  // 300
    const HALF_H = H / 2;
    const FOV = Math.PI / 3;  // 60°

    // Quotes oben
    const quotes = [
      "Diese URL existiert nicht. Aber die Monster schon.",
      "404: Inhalt weg. Munition voll.",
      "Falsche Seite — richtige Höllenpforte.",
      "Verlaufen? Schieß dich raus.",
      "Der Backend-Pfad führt direkt in die Hölle.",
      "Pass auf — da kommt was um die Ecke.",
      "Eine 404 zum Schießen schlägt jede leere Seite.",
    ];
    const quoteEl = document.getElementById("lost-quote");
    if (quoteEl) quoteEl.textContent = quotes[Math.floor(Math.random() * quotes.length)];

    const goLines = [
      "Die Bugs feiern. Wahrscheinlich.",
      "Du hast länger durchgehalten als so manche Production-Pipeline.",
      "Mehr Welle als Production-Issues kurz vor Release.",
      "Ein guter Lauf für jemanden, der die falsche URL erwischt hat.",
      "Bugs 1, du 0. Aber stilvoll verloren.",
    ];

    // Mobile-Check: Touch-only ohne Maus → Hinweis statt Spiel
    const mqCoarse = window.matchMedia && window.matchMedia("(pointer: coarse)").matches;
    const noPointerLock = !("pointerLockElement" in document) && !("mozPointerLockElement" in document);
    const mobileOnly = mqCoarse && noPointerLock;
    if (mqCoarse && "ontouchstart" in window && !window.matchMedia("(min-width: 800px)").matches) {
      document.getElementById("mobile-note").hidden = false;
      document.getElementById("overlay-start").hidden = true;
      // Wir lassen den Renderer trotzdem laufen, aber ohne Interaktion.
    }

    // ---------- Map ----------
    // 1 = Wand, 0 = Boden. 16x16 Arena mit Korridoren und Räumen.
    const MAP = [
      "1111111111111111",
      "1000000000000001",
      "1011110111111101",
      "1010000000000101",
      "1010111111110101",
      "1000100000010101",
      "1110101111010101",
      "1000101000010101",
      "1010111010110101",
      "1010000010000001",
      "1011111110111111",
      "1000001000000001",
      "1011101011110101",
      "1000001000010101",
      "1011111111110101",
      "1111111111111111",
    ];
    const MAP_W = MAP[0].length;
    const MAP_H = MAP.length;
    function mapAt(x, y) {
      if (x < 0 || x >= MAP_W || y < 0 || y >= MAP_H) return "1";
      return MAP[y][x];
    }
    function isWall(x, y) { return mapAt(Math.floor(x), Math.floor(y)) === "1"; }
    function isFloor(x, y) { return mapAt(Math.floor(x), Math.floor(y)) === "0"; }

    // Liste aller freien Zellen für Enemy-Spawning
    const freeCells = [];
    for (let y = 0; y < MAP_H; y++) for (let x = 0; x < MAP_W; x++) {
      if (MAP[y][x] === "0") freeCells.push([x + 0.5, y + 0.5]);
    }

    // ---------- State ----------
    const player = {
      x: 1.5, y: 1.5, angle: Math.PI / 4,
      hp: 100, maxHp: 100,
      moveSpeed: 3.2,         // Felder/Sekunde
      rotSpeed: 0.0026,       // rad pro Pixel Maus-Bewegung
      kills: 0, score: 0,
      iFrames: 0,
    };

    const weapon = {
      damage: 22,
      fireRate: 180,          // ms
      cooldown: 0,
      magSize: 30,
      ammo: 30,
      reserve: Infinity,
      reloading: false,
      reloadTime: 900,        // ms
      reloadTimer: 0,
      recoil: 0,              // visuell, dezent
    };

    /** @type {Array<{x:number,y:number,hp:number,maxHp:number,type:string,speed:number,r:number,dmg:number,emoji:string,xp:number,hitFlash:number,atkCd:number}>} */
    const enemies = [];
    /** @type {Array<{x:number,y:number,ttl:number,vx:number,vy:number,size:number,color:string}>} */
    const particles = [];
    let muzzleFlash = 0;
    let damageFlash = 0;

    const enemyTypes = {
      bug:   { hp: 28,  speed: 1.3, r: 0.3, dmg: 8,  emoji: "🐛", color:"#84cc16" },
      snake: { hp: 55,  speed: 1.7, r: 0.32, dmg: 12, emoji: "🐍", color:"#22d3ee" },
      skull: { hp: 70,  speed: 2.0, r: 0.3, dmg: 16, emoji: "💀", color:"#e5e5e5" },
      demon: { hp: 95,  speed: 1.6, r: 0.36, dmg: 22, emoji: "👹", color:"#dc2626" },
      ghost: { hp: 40,  speed: 2.4, r: 0.28, dmg: 14, emoji: "👻", color:"#a3a3a3" },
      boss:  { hp: 350, speed: 1.2, r: 0.5, dmg: 32, emoji: "🤖", color:"#fb923c" },
    };

    let wave = 1;
    let waveTimer = 0;
    let waveActive = false;
    let timeElapsed = 0;
    let running = false;
    let paused = false;

    function spawnEnemy(type) {
      const t = enemyTypes[type];
      // weit weg vom Spieler spawnen
      let pos;
      for (let tries = 0; tries < 80; tries++) {
        const c = freeCells[Math.floor(Math.random() * freeCells.length)];
        const dx = c[0] - player.x, dy = c[1] - player.y;
        if (dx * dx + dy * dy > 16) { pos = c; break; }
      }
      if (!pos) pos = freeCells[Math.floor(Math.random() * freeCells.length)];
      enemies.push({
        x: pos[0], y: pos[1], hp: t.hp, maxHp: t.hp,
        type, speed: t.speed, r: t.r, dmg: t.dmg,
        emoji: t.emoji, hitFlash: 0, atkCd: 0,
      });
    }

    function startWave(n) {
      const count = 3 + Math.floor(n * 1.8);
      for (let i = 0; i < count; i++) {
        let pool = ["bug"];
        if (n >= 2) pool.push("snake");
        if (n >= 3) pool.push("ghost");
        if (n >= 4) pool.push("skull");
        if (n >= 5) pool.push("demon");
        const type = pool[Math.floor(Math.random() * pool.length)];
        setTimeout(() => spawnEnemy(type), i * 350);
      }
      if (n >= 4 && n % 3 === 0) {
        setTimeout(() => spawnEnemy("boss"), 800);
      }
      waveActive = true;
    }

    // ---------- Input ----------
    const keys = {};
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        if (running && !paused) {
          // Pointer-Lock-Exit triggert eh die Pause; nichts weiter
        }
        return;
      }
      keys[e.key.toLowerCase()] = true;
      if (e.key === "r" || e.key === "R") tryReload();
      if (["w","a","s","d"].includes(e.key.toLowerCase())) e.preventDefault();
    });
    window.addEventListener("keyup", (e) => {
      keys[e.key.toLowerCase()] = false;
    });

    // Pointer-Lock
    const frame = document.getElementById("game-frame");
    canvas.addEventListener("click", () => {
      if (!running) return;
      if (document.pointerLockElement !== canvas) canvas.requestPointerLock?.();
    });
    document.addEventListener("pointerlockchange", () => {
      if (!running) return;
      if (document.pointerLockElement === canvas) {
        paused = false;
        document.getElementById("overlay-pause").hidden = true;
        lastT = performance.now();
      } else {
        // Pointer-Lock weg → Pause
        if (!document.getElementById("overlay-gameover").hidden) return;
        paused = true;
        document.getElementById("overlay-pause").hidden = false;
      }
    });
    document.addEventListener("mousemove", (e) => {
      if (document.pointerLockElement !== canvas) return;
      player.angle += e.movementX * player.rotSpeed;
    });
    canvas.addEventListener("mousedown", (e) => {
      if (!running || paused) return;
      if (document.pointerLockElement !== canvas) return;
      if (e.button === 0) shoot();
    });

    function tryReload() {
      if (!running || paused) return;
      if (weapon.reloading) return;
      if (weapon.ammo >= weapon.magSize) return;
      weapon.reloading = true;
      weapon.reloadTimer = weapon.reloadTime;
    }

    // ---------- Movement ----------
    function tryMove(dx, dy) {
      const pad = 0.2;
      // X-Achse separat (sliding entlang Wänden)
      if (!isWall(player.x + dx + Math.sign(dx) * pad, player.y)) player.x += dx;
      if (!isWall(player.x, player.y + dy + Math.sign(dy) * pad)) player.y += dy;
    }

    // ---------- Shooting ----------
    function shoot() {
      if (weapon.cooldown > 0 || weapon.reloading) return;
      if (weapon.ammo <= 0) { tryReload(); return; }
      weapon.ammo--;
      weapon.cooldown = weapon.fireRate;
      weapon.recoil = 1;
      muzzleFlash = 80;

      // Ray vom Spieler in Blickrichtung, prüfe Enemy-Treffer vor Wand-Hit
      const cos = Math.cos(player.angle), sin = Math.sin(player.angle);
      // Wand-Distanz per DDA
      const wallDist = castWallRay(player.x, player.y, cos, sin).dist;
      // Engste Treffer auf Gegner finden
      let best = null, bestDist = wallDist;
      const aimTolerance = 0.08; // Toleranz quer zur Blickrichtung pro Distanz
      for (const e of enemies) {
        const dx = e.x - player.x, dy = e.y - player.y;
        const along = dx * cos + dy * sin;    // entlang Blickrichtung
        if (along <= 0 || along >= bestDist) continue;
        const across = Math.abs(-dx * sin + dy * cos); // quer
        if (across < e.r + aimTolerance * along) {
          best = e;
          bestDist = along;
        }
      }
      if (best) {
        best.hp -= weapon.damage;
        best.hitFlash = 120;
        // Blutpartikel
        for (let i = 0; i < 6; i++) {
          particles.push({
            x: best.x, y: best.y, ttl: 0.5,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5,
            size: 0.1 + Math.random() * 0.15,
            color: "#ef4444",
          });
        }
        if (best.hp <= 0) {
          player.kills++;
          player.score += 50;
          enemies.splice(enemies.indexOf(best), 1);
        }
      }
    }

    // ---------- Wall Raycasting (DDA) ----------
    function castWallRay(px, py, dx, dy) {
      // Schutz vor Division durch 0
      const eps = 1e-9;
      const ddx = dx === 0 ? eps : dx;
      const ddy = dy === 0 ? eps : dy;

      let mapX = Math.floor(px), mapY = Math.floor(py);
      const deltaX = Math.abs(1 / ddx), deltaY = Math.abs(1 / ddy);
      let stepX, stepY, sideX, sideY;

      if (ddx < 0) { stepX = -1; sideX = (px - mapX) * deltaX; }
      else         { stepX = 1;  sideX = (mapX + 1 - px) * deltaX; }
      if (ddy < 0) { stepY = -1; sideY = (py - mapY) * deltaY; }
      else         { stepY = 1;  sideY = (mapY + 1 - py) * deltaY; }

      let side, hit = 0;
      for (let i = 0; i < 64 && !hit; i++) {
        if (sideX < sideY) {
          sideX += deltaX; mapX += stepX; side = 0;
        } else {
          sideY += deltaY; mapY += stepY; side = 1;
        }
        if (mapAt(mapX, mapY) === "1") hit = 1;
      }
      const dist = side === 0 ? (sideX - deltaX) : (sideY - deltaY);
      let wallX = side === 0 ? py + dist * ddy : px + dist * ddx;
      wallX -= Math.floor(wallX);
      return { dist: Math.max(0.0001, dist), side, mapX, mapY, wallX };
    }

    // ---------- Render ----------
    const zBuffer = new Float32Array(W);

    function render() {
      // Boden + Decke (einfacher Gradient — kein Floorcasting für Performance)
      ctx.fillStyle = "#1a0f0a";
      ctx.fillRect(0, 0, W, HALF_H);
      ctx.fillStyle = "#2a1c11";
      ctx.fillRect(0, HALF_H, W, HALF_H);

      // Subtile Bodenstreifen für Tiefenwirkung
      ctx.fillStyle = "rgba(0,0,0,0.18)";
      for (let i = 0; i < 10; i++) {
        const y = HALF_H + (i * i) * 1.2;
        if (y > H) break;
        ctx.fillRect(0, y, W, 1);
      }

      // Wände: 1 Ray pro Spalte
      for (let x = 0; x < W; x++) {
        const cameraX = 2 * x / W - 1;        // -1 bis +1
        const rayAngle = player.angle + cameraX * (FOV / 2);
        const cos = Math.cos(rayAngle), sin = Math.sin(rayAngle);
        const hit = castWallRay(player.x, player.y, cos, sin);
        // Fisheye-Korrektur
        const perpDist = hit.dist * Math.cos(rayAngle - player.angle);
        zBuffer[x] = perpDist;

        const lineHeight = Math.min(H * 3, H / perpDist);
        const drawStart = Math.max(0, Math.floor(HALF_H - lineHeight / 2));
        const drawEnd = Math.min(H, Math.floor(HALF_H + lineHeight / 2));

        // Wandfarbe: Schachbrett-Stripes für Textur-Feeling
        const stripe = (Math.floor(hit.wallX * 8) + (hit.side === 0 ? 0 : 1)) & 1;
        let base = hit.side === 1 ? 0xa64a1a : 0xc7591f;
        if (stripe) base = hit.side === 1 ? 0x873a14 : 0xa3471a;
        // Fog mit Distanz
        const fog = Math.max(0, Math.min(1, 1 - perpDist / 12));
        const r = ((base >> 16) & 0xff) * fog;
        const g = ((base >> 8) & 0xff) * fog;
        const b = (base & 0xff) * fog;
        ctx.fillStyle = "rgb(" + (r|0) + "," + (g|0) + "," + (b|0) + ")";
        ctx.fillRect(x, drawStart, 1, drawEnd - drawStart);
      }

      // Enemies & Partikel als Sprites (Z-Buffer-getestet)
      const sprites = enemies.map((e) => ({ kind: "enemy", ref: e, dx: e.x - player.x, dy: e.y - player.y }))
        .concat(particles.map((p) => ({ kind: "particle", ref: p, dx: p.x - player.x, dy: p.y - player.y })));

      // Transform & sort by depth (weit zuerst)
      for (const s of sprites) {
        const cos = Math.cos(player.angle), sin = Math.sin(player.angle);
        s.depth = s.dx * cos + s.dy * sin;
        s.transX = -s.dx * sin + s.dy * cos;
      }
      sprites.sort((a, b) => b.depth - a.depth);

      const projectionPlaneDist = (W / 2) / Math.tan(FOV / 2);

      for (const s of sprites) {
        if (s.depth <= 0.1) continue;
        const screenX = (W / 2) + (s.transX / s.depth) * projectionPlaneDist;
        const baseSize = s.kind === "enemy" ? 1.0 : (s.ref.size || 0.15);
        const size = (baseSize * H) / s.depth;
        const sx = Math.floor(screenX - size / 2);
        const sw = Math.floor(size);
        const sy = Math.floor(HALF_H - size / 2);

        if (sx + sw < 0 || sx > W) continue;

        if (s.kind === "particle") {
          // Partikel als kleiner gefärbter Punkt
          ctx.fillStyle = s.ref.color;
          ctx.globalAlpha = Math.max(0, s.ref.ttl / 0.5);
          ctx.fillRect(sx, sy, Math.max(2, sw), Math.max(2, sw));
          ctx.globalAlpha = 1;
          continue;
        }

        const e = s.ref;
        // Z-Buffer-getestet Stripe für Stripe rendern: nur Spalten zeichnen, die nicht hinter Wand sind
        // Aber Emoji als Bitmap zu rendern und dann zu maskieren ist teuer. Wir machen es so:
        //  -> Wenn die Sprite-Mitte hinter einer Wand ist, skip
        //  -> Sonst: Sprite zeichnen, aber pro Spalte clippen
        const centerCol = Math.floor(screenX);
        if (centerCol >= 0 && centerCol < W && zBuffer[centerCol] < s.depth) {
          // Mitte ist hinter Wand → komplett überspringen (vereinfacht, vermeidet teures Per-Pixel-Masking)
          continue;
        }
        // Emoji rendern
        ctx.save();
        const fontSize = Math.max(8, Math.floor(size * 0.92));
        ctx.font = fontSize + "px system-ui, 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        const cx = screenX, cy = HALF_H;
        if (e.hitFlash > 0) {
          ctx.shadowColor = "#fef9c3";
          ctx.shadowBlur = 12;
        }
        // Fog
        const fog = Math.max(0.3, Math.min(1, 1 - s.depth / 12));
        ctx.globalAlpha = fog;
        ctx.fillText(e.emoji, cx, cy);
        ctx.restore();

        // HP-Bar darüber, wenn angekratzt
        if (e.hp < e.maxHp) {
          const barW = Math.max(16, size * 0.7);
          const barX = screenX - barW / 2;
          const barY = HALF_H - size / 2 - 6;
          ctx.fillStyle = "rgba(0,0,0,0.6)";
          ctx.fillRect(barX, barY, barW, 3);
          ctx.fillStyle = "#f87171";
          ctx.fillRect(barX, barY, barW * (e.hp / e.maxHp), 3);
        }
      }

      // Mündungsfeuer und Waffe
      drawWeapon();

      // Damage-Flash overlay
      if (damageFlash > 0) {
        ctx.fillStyle = "rgba(220, 38, 38, " + (damageFlash / 300) + ")";
        ctx.fillRect(0, 0, W, H);
      }
    }

    function drawWeapon() {
      // Einfache Pixelart-Knarre unten mittig
      const cx = W / 2;
      const recoilY = weapon.recoil * 8;
      const baseY = H - 8 + recoilY;
      ctx.save();
      ctx.translate(cx, baseY);

      // Lauf
      ctx.fillStyle = "#3f3f46";
      ctx.fillRect(-3, -55, 6, 50);
      // Gehäuse
      ctx.fillStyle = "#52525b";
      ctx.fillRect(-12, -18, 24, 18);
      // Griff
      ctx.fillStyle = "#27272a";
      ctx.fillRect(-8, 0, 16, 12);
      // Highlight
      ctx.fillStyle = "#71717a";
      ctx.fillRect(-12, -18, 24, 2);
      ctx.fillRect(-3, -55, 1, 50);

      // Mündungsfeuer
      if (muzzleFlash > 0) {
        const a = muzzleFlash / 80;
        ctx.globalAlpha = a;
        ctx.fillStyle = "#fde047";
        ctx.beginPath();
        ctx.moveTo(0, -60);
        ctx.lineTo(-8, -55);
        ctx.lineTo(-3, -50);
        ctx.lineTo(-6, -45);
        ctx.lineTo(0, -50);
        ctx.lineTo(6, -45);
        ctx.lineTo(3, -50);
        ctx.lineTo(8, -55);
        ctx.closePath();
        ctx.fill();
        ctx.fillStyle = "#fef9c3";
        ctx.fillRect(-2, -62, 4, 4);
        ctx.globalAlpha = 1;
      }
      ctx.restore();
    }

    // ---------- Update ----------
    function update(dt) {
      timeElapsed += dt;

      // Bewegung
      let mx = 0, my = 0;
      if (keys.w) my += 1;
      if (keys.s) my -= 1;
      if (keys.a) mx -= 1;
      if (keys.d) mx += 1;
      const mag = Math.hypot(mx, my);
      if (mag > 0) {
        mx /= mag; my /= mag;
        const cos = Math.cos(player.angle), sin = Math.sin(player.angle);
        const dx = (cos * my + (-sin) * mx) * player.moveSpeed * dt;
        const dy = (sin * my + (cos) * mx) * player.moveSpeed * dt;
        tryMove(dx, dy);
      }

      // Cooldowns
      weapon.cooldown = Math.max(0, weapon.cooldown - dt * 1000);
      if (weapon.recoil > 0) weapon.recoil = Math.max(0, weapon.recoil - dt * 6);
      if (muzzleFlash > 0) muzzleFlash = Math.max(0, muzzleFlash - dt * 1000);
      if (damageFlash > 0) damageFlash = Math.max(0, damageFlash - dt * 1000);
      if (player.iFrames > 0) player.iFrames = Math.max(0, player.iFrames - dt * 1000);

      // Reload
      if (weapon.reloading) {
        weapon.reloadTimer -= dt * 1000;
        if (weapon.reloadTimer <= 0) {
          weapon.ammo = weapon.magSize;
          weapon.reloading = false;
        }
      }

      // Welle
      if (!waveActive && enemies.length === 0) {
        waveTimer += dt;
        if (waveTimer > 2.5) {
          waveTimer = 0;
          wave++;
          startWave(wave);
          document.getElementById("hud-wave").textContent = String(wave);
        }
      } else if (enemies.length === 0) {
        waveActive = false;
      }

      // Auto-Reload bei leerem Mag, wenn Spieler nicht schießt
      if (weapon.ammo === 0 && !weapon.reloading) tryReload();

      // Gegner bewegen / angreifen
      for (let i = enemies.length - 1; i >= 0; i--) {
        const e = enemies[i];
        if (e.hitFlash > 0) e.hitFlash = Math.max(0, e.hitFlash - dt * 1000);
        if (e.atkCd > 0) e.atkCd = Math.max(0, e.atkCd - dt * 1000);

        const dx = player.x - e.x, dy = player.y - e.y;
        const d = Math.hypot(dx, dy);
        if (d > 0.001) {
          const nx = dx / d, ny = dy / d;
          // Move-with-collision
          const step = e.speed * dt;
          const newX = e.x + nx * step;
          const newY = e.y + ny * step;
          if (!isWall(newX, e.y)) e.x = newX;
          if (!isWall(e.x, newY)) e.y = newY;
        }
        // Angriff bei Kontakt
        if (d < e.r + 0.4 && e.atkCd <= 0 && player.iFrames <= 0) {
          player.hp -= e.dmg;
          e.atkCd = 800;
          player.iFrames = 400;
          damageFlash = 280;
          if (player.hp <= 0) { player.hp = 0; endGame(); return; }
        }
      }
      // Enemies entstacken
      for (let i = 0; i < enemies.length; i++) {
        for (let j = i + 1; j < enemies.length; j++) {
          const a = enemies[i], b = enemies[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const d = Math.hypot(dx, dy);
          const min = a.r + b.r;
          if (d > 0 && d < min) {
            const push = (min - d) / 2;
            const nx = dx / d, ny = dy / d;
            if (!isWall(a.x - nx * push * 0.4, a.y - ny * push * 0.4)) {
              a.x -= nx * push * 0.4; a.y -= ny * push * 0.4;
            }
            if (!isWall(b.x + nx * push * 0.4, b.y + ny * push * 0.4)) {
              b.x += nx * push * 0.4; b.y += ny * push * 0.4;
            }
          }
        }
      }

      // Partikel
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.x += p.vx * dt; p.y += p.vy * dt;
        p.ttl -= dt;
        if (p.ttl <= 0) particles.splice(i, 1);
      }
    }

    // ---------- HUD ----------
    const elWave = document.getElementById("hud-wave");
    const elKills = document.getElementById("hud-kills");
    const elTime = document.getElementById("hud-time");
    const elHp = document.getElementById("hud-hp");
    const elHpFill = document.getElementById("hud-hp-fill");
    const elAmmo = document.getElementById("hud-ammo");

    function fmtTime(s) {
      const m = Math.floor(s / 60);
      const r = Math.floor(s % 60);
      return m + ":" + String(r).padStart(2, "0");
    }
    function syncHud() {
      elWave.textContent = String(wave);
      elKills.textContent = String(player.kills);
      elTime.textContent = fmtTime(timeElapsed);
      elHp.textContent = String(Math.ceil(player.hp));
      elHpFill.style.transform = "scaleX(" + (player.hp / player.maxHp) + ")";
      const ammoText = weapon.reloading
        ? "RELOAD..."
        : (weapon.ammo + " / ∞");
      elAmmo.textContent = ammoText;
    }

    // ---------- Loop ----------
    let lastT = 0;
    function loop(t) {
      if (!running) return;
      const dt = Math.min(0.05, (t - lastT) / 1000);
      lastT = t;
      if (!paused) {
        update(dt);
        if (!running) return;
      }
      render();
      syncHud();
      requestAnimationFrame(loop);
    }

    // ---------- Lifecycle ----------
    function reset() {
      enemies.length = 0;
      particles.length = 0;
      player.x = 1.5; player.y = 1.5; player.angle = Math.PI / 4;
      player.hp = 100; player.maxHp = 100;
      player.kills = 0; player.score = 0; player.iFrames = 0;
      weapon.ammo = weapon.magSize;
      weapon.reloading = false; weapon.cooldown = 0; weapon.recoil = 0;
      wave = 0; waveTimer = 2.5; waveActive = false;
      timeElapsed = 0;
      muzzleFlash = 0; damageFlash = 0;
    }
    function startGame() {
      reset();
      document.getElementById("overlay-start").hidden = true;
      document.getElementById("overlay-gameover").hidden = true;
      document.getElementById("overlay-pause").hidden = true;
      running = true;
      paused = false;
      lastT = performance.now();
      requestAnimationFrame(loop);
      // Pointer-Lock anfordern
      setTimeout(() => canvas.requestPointerLock?.(), 50);
    }
    function endGame() {
      running = false;
      document.exitPointerLock?.();
      document.getElementById("go-time").textContent = fmtTime(timeElapsed);
      document.getElementById("go-kills").textContent = String(player.kills);
      document.getElementById("go-wave").textContent = String(wave);
      document.getElementById("go-line").textContent =
        goLines[Math.floor(Math.random() * goLines.length)];
      document.getElementById("overlay-gameover").hidden = false;
    }

    document.getElementById("btn-start").addEventListener("click", startGame);
    document.getElementById("btn-restart").addEventListener("click", startGame);
    document.getElementById("btn-resume").addEventListener("click", () => {
      canvas.requestPointerLock?.();
    });

    // Initiales Bild zeichnen, damit Frame nicht leer ist
    render();
  })();
</script>
