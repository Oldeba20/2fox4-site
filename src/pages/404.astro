---
/**
 * 404 — "Ups, verlaufen!"
 *
 * Pseudo-3D-Ego-Shooter im Doom-Stil mit Raycasting-Renderer,
 * Pointer-Lock + Pitch-Maussteuerung, WASD-Bewegung, Doppelläufiger
 * Schrotflinte mit Händen, optionalen Sounds.
 *
 * Apache liefert /404.html bei nicht gefundenen URLs aus (ErrorDocument
 * 404 /404.html steht in der Server-.htaccess).
 */
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Ups, verlaufen! — 2fox4";
const description =
  "Die gesuchte Seite gibt es nicht — aber dafür ein kleines Spiel zum Zeitvertreib.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <section class="lost-page">
    <header class="lost-hero">
      <h1 class="lost-title">Ups, verlaufen.</h1>
      <p class="lost-hint">
        <kbd>WASD</kbd> laufen · Maus umsehen · <kbd>Klick</kbd> Feuer
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-sm" href="/">← Zurück zur Startseite</a>
        <button class="btn btn-ghost btn-sm" id="hud-sound" type="button" aria-label="Sound an/aus">
          <span id="sound-icon">🔇</span>&nbsp;Sound:&nbsp;<span id="sound-state">aus</span>
        </button>
      </div>
    </header>

    <div class="game-wrapper">
      <div class="game-frame" id="game-frame">
        <canvas id="fps-canvas" width="480" height="300"></canvas>

        <!-- HUD-Overlay -->
        <div class="hud" aria-live="polite">
          <div class="hud-row hud-top">
            <div class="hud-chip">
              <span class="hud-label">Welle</span>
              <span class="hud-value" id="hud-wave">1</span>
            </div>
            <div class="hud-chip">
              <span class="hud-label">Kills</span>
              <span class="hud-value" id="hud-kills">0</span>
            </div>
            <div class="hud-chip">
              <span class="hud-label">Zeit</span>
              <span class="hud-value" id="hud-time">0:00</span>
            </div>
          </div>
          <div class="hud-bottom">
            <div class="hud-stat hud-stat-hp">
              <div class="hud-stat-label">HP</div>
              <div class="hud-bar">
                <div class="hud-bar-fill" id="hud-hp-fill"></div>
              </div>
              <div class="hud-stat-num" id="hud-hp">100</div>
            </div>
            <div class="hud-stat hud-stat-ammo">
              <div class="hud-stat-label">SHELLS</div>
              <div class="hud-stat-num hud-stat-num-lg" id="hud-ammo">8 / ∞</div>
            </div>
          </div>
        </div>

        <!-- Crosshair -->
        <div class="crosshair" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
        </div>

        <!-- Start-Overlay -->
        <div class="overlay" id="overlay-start">
          <div class="overlay-card">
            <h2>🧟 Eintreten in die Zombie-Welle?</h2>
            <p class="overlay-sub">
              Doppelläufige raus, jeder Treffer killt. Überlebe so viele
              Wellen wie du kannst.
            </p>
            <ul class="overlay-list">
              <li><kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> — laufen / strafen</li>
              <li>Maus — umsehen (links/rechts <em>und</em> hoch/runter)</li>
              <li>Klick — schießen · <kbd>R</kbd> — nachladen</li>
              <li><kbd>ESC</kbd> — Pause</li>
            </ul>
            <button class="btn btn-primary btn-lg" id="btn-start" type="button">
              ▶︎ Klick = Start
            </button>
            <p class="overlay-note">
              Maus wird gesperrt (Pointer-Lock). Mit <kbd>ESC</kbd> wieder frei.
            </p>
          </div>
        </div>

        <!-- Pause-Overlay -->
        <div class="overlay overlay-pause" id="overlay-pause" hidden>
          <div class="overlay-card">
            <h2>⏸ Pause</h2>
            <button class="btn btn-primary" id="btn-resume" type="button">
              ▶︎ Weiterspielen
            </button>
          </div>
        </div>

        <!-- Game-Over-Overlay -->
        <div class="overlay overlay-gameover" id="overlay-gameover" hidden>
          <div class="overlay-card">
            <h2>💀 Game Over</h2>
            <p class="overlay-stat">
              Du hast <strong id="go-time">0:00</strong> überlebt,
              <strong id="go-kills">0</strong> Zombies erledigt
              und Welle <strong id="go-wave">1</strong> erreicht.
            </p>
            <p class="overlay-line" id="go-line">
              Die Zombies feiern. Wahrscheinlich.
            </p>
            <div class="overlay-actions">
              <button class="btn btn-primary" id="btn-restart" type="button">
                ↻ Nochmal
              </button>
              <a class="btn btn-ghost" href="/">Zurück zur Startseite</a>
            </div>
          </div>
        </div>

        <!-- Mobile-Hinweis -->
        <div class="mobile-note" id="mobile-note" hidden>
          <p>📱 Auf dem Handy nicht spielbar — komm gerne mit Maus + Tastatur wieder.</p>
          <a href="/" class="btn btn-primary">← Zur Startseite</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .lost-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0.75rem 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lost-hero {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    align-items: center;
    margin-bottom: 0.2rem;
  }
  .lost-title {
    font-size: clamp(1.4rem, 2.6vw, 1.85rem);
    margin: 0;
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 800;
  }
  .lost-hint {
    font-size: 0.82rem;
    color: #6b7280;
    margin: 0;
  }
  kbd {
    font-family: "JetBrains Mono Variable", monospace;
    background: #f3f4f6;
    border: 1px solid #d1d5db;
    border-bottom-width: 2px;
    border-radius: 4px;
    padding: 0 5px;
    margin: 0 1px;
    font-size: 0.82em;
    color: #111827;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.9rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    transition: transform 0.1s, background 0.15s;
    font-family: inherit;
  }
  .btn:hover { transform: translateY(-1px); }
  .btn-sm { padding: 0.3rem 0.8rem; font-size: 0.82rem; }
  .btn-primary { background: #b91c1c; color: #fff; }
  .btn-primary:hover { background: #991b1b; }
  .btn-ghost {
    background: transparent;
    color: #111827;
    border-color: #d1d5db;
  }
  .btn-ghost:hover { background: #f3f4f6; }
  .btn-lg { padding: 0.7rem 1.2rem; font-size: 1rem; }

  /* Game */
  .game-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    align-items: center;
    width: 100%;
  }
  .game-frame {
    position: relative;
    width: 100%;
    max-width: 960px;
    aspect-ratio: 8 / 5;
    background: #0a0a0a;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 25px 60px -20px rgba(0,0,0,0.6),
                inset 0 0 0 1px rgba(255,255,255,0.05);
    cursor: crosshair;
    user-select: none;
  }
  #fps-canvas {
    display: block;
    width: 100%;
    height: 100%;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    background: #000;
  }

  /* Crosshair */
  .crosshair {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 18px;
    margin: -9px 0 0 -9px;
    pointer-events: none;
    z-index: 3;
  }
  .crosshair span {
    position: absolute;
    background: rgba(255, 255, 255, 0.7);
    box-shadow: 0 0 4px rgba(0,0,0,0.7);
  }
  .crosshair span:nth-child(1) { left: 50%; top: 0; width: 2px; height: 6px; margin-left: -1px; }
  .crosshair span:nth-child(2) { left: 50%; bottom: 0; width: 2px; height: 6px; margin-left: -1px; }
  .crosshair span:nth-child(3) { top: 50%; left: 0; height: 2px; width: 6px; margin-top: -1px; }
  .crosshair span:nth-child(4) { top: 50%; right: 0; height: 2px; width: 6px; margin-top: -1px; }

  /* HUD */
  .hud {
    position: absolute;
    inset: 0;
    pointer-events: none;
    color: #fef3c7;
    font-family: "JetBrains Mono Variable", monospace;
    z-index: 2;
  }
  .hud-row {
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .hud-chip {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    background: rgba(0,0,0,0.7);
    border: 1px solid rgba(252, 211, 77, 0.3);
    border-radius: 3px;
    padding: 0.2rem 0.55rem;
    font-size: 0.74rem;
  }
  .hud-label {
    text-transform: uppercase;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    opacity: 0.65;
  }
  .hud-value { font-weight: 700; font-size: 0.9rem; color: #fbbf24; }

  .hero-actions {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    margin-top: 0.15rem;
  }
  #hud-sound {
    cursor: pointer;
    background: #fbbf24;
    color: #111827;
    border-color: #d97706;
    font-weight: 700;
  }
  #hud-sound:hover { background: #f59e0b; }
  #hud-sound.sound-off {
    background: #e5e7eb;
    border-color: #9ca3af;
    color: #374151;
  }
  #hud-sound.sound-off:hover { background: #d1d5db; }
  .hud-bottom {
    position: absolute;
    left: 10px;
    right: 10px;
    bottom: 10px;
    display: flex;
    gap: 0.75rem;
    align-items: flex-end;
    justify-content: space-between;
  }
  .hud-stat { display: flex; flex-direction: column; gap: 0.2rem; min-width: 140px; }
  .hud-stat-label {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    opacity: 0.6;
    text-transform: uppercase;
  }
  .hud-stat-num {
    font-size: 1rem;
    font-weight: 800;
    color: #fbbf24;
    text-shadow: 0 0 6px rgba(251, 191, 36, 0.3);
  }
  .hud-stat-num-lg { font-size: 1.3rem; }
  .hud-stat-ammo { text-align: right; }
  .hud-bar {
    height: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(252, 211, 77, 0.25);
    border-radius: 2px;
    overflow: hidden;
    position: relative;
  }
  .hud-bar-fill {
    position: absolute;
    inset: 0;
    width: 100%;
    transform-origin: left center;
    background: linear-gradient(90deg, #dc2626, #f97316, #fbbf24);
    transition: transform 0.2s;
  }

  /* Overlays */
  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(8, 6, 6, 0.85);
    backdrop-filter: blur(4px);
    color: #fef3c7;
    z-index: 10;
    padding: 1rem;
  }
  .overlay[hidden] { display: none; }
  .overlay-card {
    background: #1c1917;
    border: 1px solid rgba(252, 211, 77, 0.2);
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    max-width: 26rem;
    width: 100%;
    text-align: center;
  }
  .overlay-card h2 { margin: 0 0 0.4rem; font-size: 1.2rem; color: #fbbf24; }
  .overlay-sub { color: #d6d3d1; margin: 0 0 0.7rem; font-size: 0.88rem; }
  .overlay-list {
    text-align: left;
    list-style: none;
    padding: 0;
    margin: 0 0 0.9rem;
    color: #d6d3d1;
    font-size: 0.82rem;
    display: grid;
    gap: 0.2rem;
  }
  .overlay-list kbd {
    background: #292524;
    border-color: #44403c;
    color: #fef3c7;
  }
  .overlay-note {
    font-size: 0.72rem;
    color: #a8a29e;
    margin: 0.5rem 0 0;
  }
  .overlay-stat strong { color: #fbbf24; }
  .overlay-line { font-style: italic; color: #a8a29e; }
  .overlay-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 0.6rem;
  }

  .mobile-note {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    justify-content: center;
    background: rgba(8, 6, 6, 0.95);
    color: #fef3c7;
    text-align: center;
    padding: 1.5rem;
    z-index: 20;
  }
  .mobile-note[hidden] { display: none; }
  .mobile-note p { margin: 0; max-width: 22rem; }

  @media (max-width: 640px) {
    .hud-stat { min-width: 90px; }
    .hud-stat-num-lg { font-size: 1.05rem; }
  }
</style>

<script is:inline>
  (function () {
    "use strict";

    const canvas = document.getElementById("fps-canvas");
    if (!canvas) return;
    const ctx = canvas.getContext("2d");
    ctx.imageSmoothingEnabled = false;

    const W = canvas.width;
    const H = canvas.height;
    const HALF_H = H / 2;
    const FOV = Math.PI / 3;

    // ---------- Map (offene Arena mit Säulen) ----------
    const MAP = [
      "1111111111111111",
      "1000000000000001",
      "1001000000010001",
      "1000000010000001",
      "1000010000001001",
      "1010000000000001",
      "1000000100000001",
      "1000010000010001",
      "1001000000000001",
      "1000000010000001",
      "1000100000000101",
      "1000000001000001",
      "1010000000000001",
      "1000010000010001",
      "1000000000000001",
      "1111111111111111",
    ];
    const MAP_W = MAP[0].length;
    const MAP_H = MAP.length;
    function mapAt(x, y) {
      if (x < 0 || x >= MAP_W || y < 0 || y >= MAP_H) return "1";
      return MAP[y][x];
    }
    function isWall(x, y) { return mapAt(Math.floor(x), Math.floor(y)) === "1"; }

    const freeCells = [];
    for (let y = 0; y < MAP_H; y++) for (let x = 0; x < MAP_W; x++) {
      if (MAP[y][x] === "0") freeCells.push([x + 0.5, y + 0.5]);
    }

    // ---------- State ----------
    const player = {
      x: 7.5, y: 7.5, angle: 0, pitch: 0,
      hp: 100, maxHp: 100,
      moveSpeed: 3.4,
      rotSpeed: 0.0028,
      pitchSpeed: 0.7,        // mal e.movementY, dann begrenzt
      kills: 0, score: 0,
      iFrames: 0,
    };
    const PITCH_LIMIT = 120;

    const weapon = {
      damage: 32,             // Schrotflinte haut zu
      fireRate: 380,
      cooldown: 0,
      magSize: 8,
      ammo: 8,
      reloading: false,
      reloadTime: 1100,
      reloadTimer: 0,
      recoil: 0,
      pelletCount: 5,          // mehrere Pellets gleichzeitig
      pelletSpread: 0.08,
    };

    const enemies = [];
    const particles = [];
    let muzzleFlash = 0;
    let damageFlash = 0;

    // Alle Gegner sterben in einem Treffer (hp = 1). Variieren in Speed,
    // Schaden und Aussehen. Alle humanoid / zombieartig.
    const enemyTypes = {
      zombie:  { hp: 1, speed: 1.1, r: 0.34, dmg: 18, emoji: "🧟" },
      vampire: { hp: 1, speed: 1.5, r: 0.34, dmg: 16, emoji: "🧛" },
      troll:   { hp: 1, speed: 0.9, r: 0.44, dmg: 26, emoji: "🧌" },
      brute:   { hp: 1, speed: 1.3, r: 0.40, dmg: 24, emoji: "👹" },
    };

    let wave = 0;
    let waveTimer = 2.5;
    let waveActive = false;
    let timeElapsed = 0;
    let running = false;
    let paused = false;

    function spawnEnemy(type) {
      const t = enemyTypes[type];
      let pos;
      for (let tries = 0; tries < 80; tries++) {
        const c = freeCells[Math.floor(Math.random() * freeCells.length)];
        const dx = c[0] - player.x, dy = c[1] - player.y;
        if (dx * dx + dy * dy > 30) { pos = c; break; } // min ~5.5 Felder weg
      }
      if (!pos) pos = freeCells[Math.floor(Math.random() * freeCells.length)];
      enemies.push({
        x: pos[0], y: pos[1], hp: t.hp, maxHp: t.hp,
        type, speed: t.speed, r: t.r, dmg: t.dmg,
        emoji: t.emoji, hitFlash: 0, atkCd: 0,
        // Erstes Stöhnen nach 0.4–2.0 Sek; spätere Intervalle skalieren mit Distanz
        groanTimer: 0.4 + Math.random() * 1.6,
      });
    }

    function startWave(n) {
      // Wave 1 = 3, Wave 2 = 4, Wave 5 = 7 — etwa ein Drittel der vorigen Werte.
      const count = 2 + Math.floor(n * 1.0);
      for (let i = 0; i < count; i++) {
        let pool = ["zombie"];
        if (n >= 2) pool.push("vampire");
        if (n >= 3) pool.push("troll");
        if (n >= 4) pool.push("brute");
        const type = pool[Math.floor(Math.random() * pool.length)];
        setTimeout(() => { if (running) spawnEnemy(type); }, i * 280);
      }
      waveActive = true;
      playWaveStart();
    }

    // ---------- Sound (Web Audio, default OFF) ----------
    let audioCtx = null;
    let soundOn = false;
    try { soundOn = localStorage.getItem("fps_sound_v1") === "1"; } catch (e) {}
    const soundBtn = document.getElementById("hud-sound");
    const soundIconEl = document.getElementById("sound-icon");
    const soundStateEl = document.getElementById("sound-state");
    function updateSoundIcon() {
      soundIconEl.textContent = soundOn ? "🔊" : "🔇";
      soundStateEl.textContent = soundOn ? "an" : "aus";
      soundBtn.classList.toggle("sound-off", !soundOn);
    }
    function ensureAudio() {
      if (!audioCtx) {
        const AC = window.AudioContext || window.webkitAudioContext;
        if (!AC) return null;
        audioCtx = new AC();
      }
      if (audioCtx.state === "suspended") audioCtx.resume();
      return audioCtx;
    }
    soundBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      soundOn = !soundOn;
      try { localStorage.setItem("fps_sound_v1", soundOn ? "1" : "0"); } catch (e) {}
      if (soundOn) ensureAudio();
      updateSoundIcon();
    });
    updateSoundIcon();

    function noiseBuffer(dur) {
      const sr = audioCtx.sampleRate;
      const buf = audioCtx.createBuffer(1, Math.floor(sr * dur), sr);
      const d = buf.getChannelData(0);
      for (let i = 0; i < d.length; i++) d[i] = (Math.random() * 2 - 1) * 0.9;
      return buf;
    }
    function playShotgun() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      // Rauschen (Schrotpartikel)
      const noise = audioCtx.createBufferSource();
      noise.buffer = noiseBuffer(0.35);
      const filter = audioCtx.createBiquadFilter();
      filter.type = "lowpass";
      filter.frequency.setValueAtTime(2400, t);
      filter.frequency.exponentialRampToValueAtTime(180, t + 0.32);
      const ng = audioCtx.createGain();
      ng.gain.setValueAtTime(0.55, t);
      ng.gain.exponentialRampToValueAtTime(0.001, t + 0.35);
      noise.connect(filter).connect(ng).connect(audioCtx.destination);
      noise.start(t);
      // Tieffrequenz-Bumms (Mündungsdruck)
      const osc = audioCtx.createOscillator();
      osc.type = "sawtooth";
      osc.frequency.setValueAtTime(110, t);
      osc.frequency.exponentialRampToValueAtTime(35, t + 0.12);
      const og = audioCtx.createGain();
      og.gain.setValueAtTime(0.35, t);
      og.gain.exponentialRampToValueAtTime(0.001, t + 0.18);
      osc.connect(og).connect(audioCtx.destination);
      osc.start(t); osc.stop(t + 0.2);
    }
    function playHit() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      osc.type = "square";
      osc.frequency.setValueAtTime(420, t);
      osc.frequency.exponentialRampToValueAtTime(80, t + 0.08);
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.25, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.1);
      osc.connect(g).connect(audioCtx.destination);
      osc.start(t); osc.stop(t + 0.12);
    }
    function playDie() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      osc.type = "sawtooth";
      osc.frequency.setValueAtTime(380, t);
      osc.frequency.exponentialRampToValueAtTime(60, t + 0.28);
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.3, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.32);
      osc.connect(g).connect(audioCtx.destination);
      osc.start(t); osc.stop(t + 0.35);
    }
    function playHurt() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      osc.type = "sawtooth";
      osc.frequency.setValueAtTime(140, t);
      osc.frequency.exponentialRampToValueAtTime(60, t + 0.22);
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.4, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.25);
      osc.connect(g).connect(audioCtx.destination);
      osc.start(t); osc.stop(t + 0.28);
    }
    function playReload() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      // Zwei Klicks (Bruch öffnen / schließen)
      for (const offset of [0, 0.45]) {
        const noise = audioCtx.createBufferSource();
        noise.buffer = noiseBuffer(0.04);
        const filter = audioCtx.createBiquadFilter();
        filter.type = "highpass";
        filter.frequency.value = 1200;
        const g = audioCtx.createGain();
        g.gain.setValueAtTime(0.3, t + offset);
        g.gain.exponentialRampToValueAtTime(0.001, t + offset + 0.06);
        noise.connect(filter).connect(g).connect(audioCtx.destination);
        noise.start(t + offset);
      }
    }
    function playWaveStart() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      const osc = audioCtx.createOscillator();
      osc.type = "sine";
      osc.frequency.setValueAtTime(55, t);
      osc.frequency.exponentialRampToValueAtTime(90, t + 0.4);
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.001, t);
      g.gain.exponentialRampToValueAtTime(0.4, t + 0.1);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.6);
      osc.connect(g).connect(audioCtx.destination);
      osc.start(t); osc.stop(t + 0.7);
    }
    function playEmpty() {
      if (!soundOn || !ensureAudio()) return;
      const t = audioCtx.currentTime;
      const noise = audioCtx.createBufferSource();
      noise.buffer = noiseBuffer(0.03);
      const g = audioCtx.createGain();
      g.gain.setValueAtTime(0.15, t);
      g.gain.exponentialRampToValueAtTime(0.001, t + 0.05);
      noise.connect(g).connect(audioCtx.destination);
      noise.start(t);
    }
    // Zombie-Stöhnen mit Lautstärke nach Distanz und Pan nach Winkel
    function playGroan(dist, pan) {
      if (!soundOn || !ensureAudio()) return;
      const vol = Math.max(0, Math.min(0.55, 0.65 - dist / 15));
      if (vol < 0.04) return;
      const t = audioCtx.currentTime;

      // Zwei Oszillatoren für vokalen Charakter
      const f1 = 80 + Math.random() * 50;
      const f2 = f1 * (2.3 + Math.random() * 0.4);

      const osc1 = audioCtx.createOscillator();
      osc1.type = "sawtooth";
      osc1.frequency.setValueAtTime(f1, t);
      osc1.frequency.linearRampToValueAtTime(f1 * 0.78, t + 0.45);
      osc1.frequency.linearRampToValueAtTime(f1 * 0.95, t + 0.75);

      const osc2 = audioCtx.createOscillator();
      osc2.type = "square";
      osc2.frequency.setValueAtTime(f2, t);
      osc2.frequency.linearRampToValueAtTime(f2 * 0.85, t + 0.5);

      const g1 = audioCtx.createGain(); g1.gain.value = 0.45;
      const g2 = audioCtx.createGain(); g2.gain.value = 0.18;

      const filter = audioCtx.createBiquadFilter();
      filter.type = "lowpass";
      filter.frequency.value = 700;
      filter.Q.value = 4;

      const master = audioCtx.createGain();
      master.gain.setValueAtTime(0.001, t);
      master.gain.exponentialRampToValueAtTime(vol, t + 0.08);
      master.gain.linearRampToValueAtTime(vol * 0.6, t + 0.55);
      master.gain.exponentialRampToValueAtTime(0.001, t + 0.85);

      osc1.connect(g1).connect(filter);
      osc2.connect(g2).connect(filter);
      filter.connect(master);

      if (audioCtx.createStereoPanner) {
        const panner = audioCtx.createStereoPanner();
        panner.pan.value = Math.max(-1, Math.min(1, pan));
        master.connect(panner).connect(audioCtx.destination);
      } else {
        master.connect(audioCtx.destination);
      }
      osc1.start(t); osc1.stop(t + 0.9);
      osc2.start(t); osc2.stop(t + 0.9);
    }

    // ---------- Input ----------
    const keys = {};
    window.addEventListener("keydown", (e) => {
      if (e.key === "Escape") return; // Pointer-Lock-Exit handhabt das
      keys[e.key.toLowerCase()] = true;
      if (e.key === "r" || e.key === "R") tryReload();
      if (["w","a","s","d"].includes(e.key.toLowerCase())) e.preventDefault();
    });
    window.addEventListener("keyup", (e) => {
      keys[e.key.toLowerCase()] = false;
    });

    canvas.addEventListener("click", () => {
      if (!running) return;
      if (document.pointerLockElement !== canvas) canvas.requestPointerLock?.();
    });
    document.addEventListener("pointerlockchange", () => {
      if (!running) return;
      if (document.pointerLockElement === canvas) {
        paused = false;
        document.getElementById("overlay-pause").hidden = true;
        lastT = performance.now();
      } else {
        if (!document.getElementById("overlay-gameover").hidden) return;
        paused = true;
        document.getElementById("overlay-pause").hidden = false;
      }
    });
    document.addEventListener("mousemove", (e) => {
      if (document.pointerLockElement !== canvas) return;
      player.angle += e.movementX * player.rotSpeed;
      player.pitch -= e.movementY * player.pitchSpeed;
      if (player.pitch > PITCH_LIMIT) player.pitch = PITCH_LIMIT;
      if (player.pitch < -PITCH_LIMIT) player.pitch = -PITCH_LIMIT;
    });
    canvas.addEventListener("mousedown", (e) => {
      if (!running || paused) return;
      if (document.pointerLockElement !== canvas) return;
      if (e.button === 0) shoot();
    });

    function tryReload() {
      if (!running || paused) return;
      if (weapon.reloading) return;
      if (weapon.ammo >= weapon.magSize) return;
      weapon.reloading = true;
      weapon.reloadTimer = weapon.reloadTime;
      playReload();
    }

    function tryMove(dx, dy) {
      const pad = 0.2;
      if (!isWall(player.x + dx + Math.sign(dx) * pad, player.y)) player.x += dx;
      if (!isWall(player.x, player.y + dy + Math.sign(dy) * pad)) player.y += dy;
    }

    function shoot() {
      if (weapon.cooldown > 0 || weapon.reloading) return;
      if (weapon.ammo <= 0) { playEmpty(); tryReload(); return; }
      weapon.ammo--;
      weapon.cooldown = weapon.fireRate;
      weapon.recoil = 1;
      muzzleFlash = 90;
      playShotgun();

      // Mehrere Pellets — Spread um Blickrichtung
      const hitsThisShot = new Set();
      for (let p = 0; p < weapon.pelletCount; p++) {
        const spread = (Math.random() - 0.5) * 2 * weapon.pelletSpread;
        const angle = player.angle + spread;
        const cos = Math.cos(angle), sin = Math.sin(angle);
        const wallDist = castWallRay(player.x, player.y, cos, sin).dist;
        let best = null, bestDist = wallDist;
        const aimTol = 0.06;
        for (const e of enemies) {
          if (hitsThisShot.has(e)) continue;
          const dx = e.x - player.x, dy = e.y - player.y;
          const along = dx * cos + dy * sin;
          if (along <= 0 || along >= bestDist) continue;
          const across = Math.abs(-dx * sin + dy * cos);
          if (across < e.r + aimTol * along) {
            best = e; bestDist = along;
          }
        }
        if (best) {
          best.hp -= weapon.damage / weapon.pelletCount * 1.5;
          best.hitFlash = 110;
          hitsThisShot.add(best);
          for (let i = 0; i < 3; i++) {
            particles.push({
              x: best.x, y: best.y, ttl: 0.5,
              vx: (Math.random() - 0.5) * 1.2,
              vy: (Math.random() - 0.5) * 1.2,
              size: 0.12 + Math.random() * 0.12,
              color: "#ef4444",
            });
          }
        }
      }
      // Kill-Auswertung
      for (let i = enemies.length - 1; i >= 0; i--) {
        if (enemies[i].hp <= 0) {
          player.kills++;
          player.score += 50;
          playDie();
          enemies.splice(i, 1);
        }
      }
      // Hit-Sound, wenn mind. ein Pellet getroffen hat
      if (hitsThisShot.size > 0) playHit();
    }

    // ---------- Wall Raycasting (DDA) ----------
    function castWallRay(px, py, dx, dy) {
      const eps = 1e-9;
      const ddx = dx === 0 ? eps : dx;
      const ddy = dy === 0 ? eps : dy;
      let mapX = Math.floor(px), mapY = Math.floor(py);
      const deltaX = Math.abs(1 / ddx), deltaY = Math.abs(1 / ddy);
      let stepX, stepY, sideX, sideY;
      if (ddx < 0) { stepX = -1; sideX = (px - mapX) * deltaX; }
      else         { stepX = 1;  sideX = (mapX + 1 - px) * deltaX; }
      if (ddy < 0) { stepY = -1; sideY = (py - mapY) * deltaY; }
      else         { stepY = 1;  sideY = (mapY + 1 - py) * deltaY; }
      let side, hit = 0;
      for (let i = 0; i < 64 && !hit; i++) {
        if (sideX < sideY) { sideX += deltaX; mapX += stepX; side = 0; }
        else { sideY += deltaY; mapY += stepY; side = 1; }
        if (mapAt(mapX, mapY) === "1") hit = 1;
      }
      const dist = side === 0 ? (sideX - deltaX) : (sideY - deltaY);
      let wallX = side === 0 ? py + dist * ddy : px + dist * ddx;
      wallX -= Math.floor(wallX);
      return { dist: Math.max(0.0001, dist), side, mapX, mapY, wallX };
    }

    // ---------- Render ----------
    const zBuffer = new Float32Array(W);

    function render() {
      const horizon = HALF_H + player.pitch;

      // Decke
      ctx.fillStyle = "#1a0f0a";
      ctx.fillRect(0, 0, W, Math.max(0, Math.min(H, horizon)));
      // Boden
      ctx.fillStyle = "#2a1c11";
      ctx.fillRect(0, Math.max(0, horizon), W, Math.max(0, H - horizon));
      // Bodenstreifen
      ctx.fillStyle = "rgba(0,0,0,0.16)";
      for (let i = 0; i < 12; i++) {
        const y = horizon + (i * i) * 1.4;
        if (y > H || y < 0) continue;
        ctx.fillRect(0, y, W, 1);
      }

      // Wände (Ziegelstein-Pattern, gestaffelte Reihen mit Mörtel)
      const BRICK_ROWS = 5;        // 5 Ziegelreihen pro Wand-Höhe
      const BRICKS_PER_ROW = 3;    // 3 Ziegel pro Welt-Einheit Wandbreite
      // Farbpalette (alle als 0xRRGGBB)
      const palBrickA_x = 0xc7591f, palBrickB_x = 0xa64a1a; // X-Seiten (hell)
      const palBrickA_y = 0x9c4d20, palBrickB_y = 0x7a3a16; // Y-Seiten (dunkler)
      const palMortar_x = 0x4a2d12, palMortar_y = 0x33200d;

      for (let x = 0; x < W; x++) {
        const cameraX = 2 * x / W - 1;
        const rayAngle = player.angle + cameraX * (FOV / 2);
        const cos = Math.cos(rayAngle), sin = Math.sin(rayAngle);
        const hit = castWallRay(player.x, player.y, cos, sin);
        const perpDist = hit.dist * Math.cos(rayAngle - player.angle);
        zBuffer[x] = perpDist;

        const lineHeight = Math.min(H * 3, H / perpDist);
        const fullStart = horizon - lineHeight / 2;
        const fog = Math.max(0, Math.min(1, 1 - perpDist / 16));

        const isYSide = hit.side === 1;
        const palBrickA = isYSide ? palBrickA_y : palBrickA_x;
        const palBrickB = isYSide ? palBrickB_y : palBrickB_x;
        const palMortar = isYSide ? palMortar_y : palMortar_x;

        for (let row = 0; row < BRICK_ROWS; row++) {
          const rowTopF = fullStart + (row / BRICK_ROWS) * lineHeight;
          const rowBotF = fullStart + ((row + 1) / BRICK_ROWS) * lineHeight;

          // Gestaffelt: jede zweite Reihe um halbe Ziegelbreite versetzt
          const xOff = (row & 1) * (0.5 / BRICKS_PER_ROW);
          const bp = (hit.wallX + xOff) * BRICKS_PER_ROW;
          const bFrac = bp - Math.floor(bp);
          const bIdx = Math.floor(bp);
          const mortarThresh = 0.06;
          const isVertMortar = bFrac < mortarThresh || bFrac > 1 - mortarThresh;

          let base = ((bIdx + row) & 1) ? palBrickA : palBrickB;
          if (isVertMortar) base = palMortar;

          const r = ((base >> 16) & 0xff) * fog;
          const g = ((base >> 8) & 0xff) * fog;
          const b = (base & 0xff) * fog;
          ctx.fillStyle = "rgb(" + (r|0) + "," + (g|0) + "," + (b|0) + ")";

          // Brick-Segment (oberer Teil), letzter 1px Reserve für Mörtel
          const segTop = Math.max(0, Math.floor(rowTopF));
          const segBot = Math.min(H, Math.floor(rowBotF) - 1);
          if (segBot > segTop) ctx.fillRect(x, segTop, 1, segBot - segTop);

          // Horizontale Mörtelfuge unter dem Brick
          const mortarY = Math.floor(rowBotF) - 1;
          if (mortarY >= 0 && mortarY < H) {
            const mb = palMortar;
            const mr = ((mb >> 16) & 0xff) * fog;
            const mg = ((mb >> 8) & 0xff) * fog;
            const mbb = (mb & 0xff) * fog;
            ctx.fillStyle = "rgb(" + (mr|0) + "," + (mg|0) + "," + (mbb|0) + ")";
            ctx.fillRect(x, mortarY, 1, 1);
          }
        }
      }

      // Sprites
      const sprites = [];
      for (const e of enemies) sprites.push({ kind: "enemy", ref: e, dx: e.x - player.x, dy: e.y - player.y });
      for (const p of particles) sprites.push({ kind: "particle", ref: p, dx: p.x - player.x, dy: p.y - player.y });

      const cosA = Math.cos(player.angle), sinA = Math.sin(player.angle);
      for (const s of sprites) {
        s.depth = s.dx * cosA + s.dy * sinA;
        s.transX = -s.dx * sinA + s.dy * cosA;
      }
      sprites.sort((a, b) => b.depth - a.depth);

      const projDist = (W / 2) / Math.tan(FOV / 2);

      for (const s of sprites) {
        if (s.depth <= 0.1) continue;
        const screenX = (W / 2) + (s.transX / s.depth) * projDist;
        // Zombies sind etwas größer als Wandhöhe (1.0) damit sie imposant wirken
        const baseSize = s.kind === "enemy" ? 1.15 : (s.ref.size || 0.18);
        const size = (baseSize * H) / s.depth;
        const sx = Math.floor(screenX - size / 2);
        const sw = Math.floor(size);
        if (sx + sw < 0 || sx > W) continue;

        // Bodenprojektion bei dieser Tiefe: hier steht der Gegner
        const floorY = horizon + HALF_H / s.depth;

        if (s.kind === "particle") {
          // Partikel etwas oberhalb des Bodens (~Körpermitte des Zombies)
          const py = floorY - (HALF_H / s.depth) * 0.5;
          ctx.fillStyle = s.ref.color;
          ctx.globalAlpha = Math.max(0, s.ref.ttl / 0.5);
          ctx.fillRect(sx, Math.floor(py - sw / 2), Math.max(2, sw), Math.max(2, sw));
          ctx.globalAlpha = 1;
          continue;
        }

        const e = s.ref;
        // Z-Buffer-Test über die Spalten der Sprite-Breite — partielle Verdeckung
        const startCol = Math.max(0, sx);
        const endCol = Math.min(W, sx + sw);
        let anyVisible = false;
        for (let c = startCol; c < endCol; c++) {
          if (zBuffer[c] > s.depth) { anyVisible = true; break; }
        }
        if (!anyVisible) continue;

        // Zentrieren so dass Sprite-Unterkante auf dem Boden steht
        const centerY = floorY - size / 2;

        ctx.save();
        const fontSize = Math.max(10, Math.floor(size * 0.95));
        ctx.font = fontSize + "px system-ui, 'Apple Color Emoji', 'Segoe UI Emoji', sans-serif";
        ctx.textAlign = "center";
        ctx.textBaseline = "middle";
        if (e.hitFlash > 0) {
          ctx.shadowColor = "#fef9c3";
          ctx.shadowBlur = 14;
        }
        const shade = Math.max(0.75, Math.min(1, 1 - s.depth / 24));
        ctx.globalAlpha = shade;
        ctx.fillText(e.emoji, screenX, centerY);
        ctx.restore();
        // HP-Bar weggelassen — alle Gegner sterben in einem Treffer
      }

      // Waffe + Hände
      drawWeapon();

      // Damage-Flash
      if (damageFlash > 0) {
        ctx.fillStyle = "rgba(220, 38, 38, " + Math.min(0.6, damageFlash / 280) + ")";
        ctx.fillRect(0, 0, W, H);
      }
    }

    // ---------- Doppelläufige + Hände (Pixel-Art, FORWARD-Pointing) ----------
    // Die Schrotflinte wird so dargestellt, als würde der Spieler "den Lauf
    // entlang nach vorne" schauen: die Mündungen sind als deutlich sichtbare
    // dunkle Kreise mit Metallring ganz oben im Sprite, die Läufe sind nur
    // kurze foreshortened Tubes, darunter Receiver, Stock und beide Hände.
    function drawWeapon() {
      const cx = W / 2;
      const recoilY = weapon.recoil * 12;
      const moving = keys.w || keys.a || keys.s || keys.d;
      const swayX = Math.sin(timeElapsed * 4) * (moving ? 2 : 0.4);
      const swayY = Math.abs(Math.sin(timeElapsed * 4)) * (moving ? 2 : 0.4);

      ctx.save();
      ctx.translate(cx + swayX, H + recoilY + swayY);

      const skin = "#d4a574";
      const skinShade = "#a67c52";
      const skinDark = "#6b4423";
      const wood = "#6b3a1a";
      const woodLite = "#8b5a2b";
      const woodDark = "#3d1f0c";
      const metal = "#52525b";
      const metalLite = "#a1a1aa";
      const metalDark = "#27272a";

      // ===== Stock (unten, läuft ins Bild raus) =====
      ctx.fillStyle = wood;
      ctx.beginPath();
      ctx.moveTo(-32, -12);
      ctx.lineTo(32, -12);
      ctx.lineTo(40, 50);
      ctx.lineTo(-12, 50);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = woodLite;
      ctx.beginPath();
      ctx.moveTo(-32, -12);
      ctx.lineTo(32, -12);
      ctx.lineTo(30, -8);
      ctx.lineTo(-30, -8);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = woodDark;
      ctx.fillRect(-12, 38, 52, 12);

      // ===== Receiver / Verschluss (Metallblock zwischen Stock und Läufen) =====
      ctx.fillStyle = metalDark;
      ctx.fillRect(-26, -38, 52, 26);
      ctx.fillStyle = metal;
      ctx.fillRect(-24, -36, 48, 22);
      ctx.fillStyle = metalLite;
      ctx.fillRect(-24, -36, 48, 2);
      ctx.fillRect(-24, -36, 2, 22);
      // Bruchstellen-Linie (zeigt die Doppelläufige)
      ctx.fillStyle = metalDark;
      ctx.fillRect(-24, -22, 48, 2);
      // Sicherungs-Hebel oben mittig
      ctx.fillStyle = metalLite;
      ctx.fillRect(-2, -36, 4, 4);

      // ===== Vorderschaft (Holzgriff über dem Receiver) =====
      ctx.fillStyle = wood;
      ctx.fillRect(-18, -58, 36, 20);
      ctx.fillStyle = woodLite;
      ctx.fillRect(-18, -58, 36, 2);
      ctx.fillRect(-18, -58, 2, 20);
      ctx.fillStyle = woodDark;
      ctx.fillRect(-18, -42, 36, 4);
      // Riffelung im Holz (für Grip)
      ctx.fillStyle = woodDark;
      for (let i = 0; i < 5; i++) {
        ctx.fillRect(-14 + i * 6, -54, 1, 14);
      }

      // ===== Läufe — KURZ, foreshortened (zeigen nach vorne, weg von der Kamera) =====
      // Pro Lauf nur ~22px sichtbar, oben Mündungs-Öffnungen
      for (const bx of [-11, 11]) {
        // Lauf-Tube
        ctx.fillStyle = metal;
        ctx.fillRect(bx - 6, -82, 12, 24);
        // Highlight links
        ctx.fillStyle = metalLite;
        ctx.fillRect(bx - 6, -82, 1, 24);
        // Schatten rechts
        ctx.fillStyle = metalDark;
        ctx.fillRect(bx + 5, -82, 1, 24);
      }
      // Brücke zwischen den Läufen
      ctx.fillStyle = metalDark;
      ctx.fillRect(-5, -82, 10, 24);
      ctx.fillStyle = metal;
      ctx.fillRect(-4, -80, 8, 20);

      // ===== Mündungs-Öffnungen — DEUTLICH SICHTBAR (zwei dunkle Löcher) =====
      for (const bx of [-11, 11]) {
        // Äußerer Metallring (heller)
        ctx.fillStyle = metalLite;
        ctx.beginPath();
        ctx.ellipse(bx, -84, 7, 5, 0, 0, Math.PI * 2);
        ctx.fill();
        // Innerer Ring (mittel)
        ctx.fillStyle = metal;
        ctx.beginPath();
        ctx.ellipse(bx, -84, 5.5, 4, 0, 0, Math.PI * 2);
        ctx.fill();
        // Schwarzes Loch (Mündung) — DAS macht klar dass man rein-guckt
        ctx.fillStyle = "#000";
        ctx.beginPath();
        ctx.ellipse(bx, -84, 4, 2.8, 0, 0, Math.PI * 2);
        ctx.fill();
        // Glanz-Highlight oben am Ring
        ctx.fillStyle = "#e4e4e7";
        ctx.fillRect(bx - 3, -89, 6, 1);
      }

      // ===== Visier / Korn vorne mittig zwischen den Läufen =====
      ctx.fillStyle = metalLite;
      ctx.fillRect(-1, -91, 2, 4);
      ctx.fillStyle = metalDark;
      ctx.fillRect(-1, -88, 2, 1);

      // ===== Linke Hand (am Vorderschaft) =====
      ctx.fillStyle = skinShade;
      ctx.fillRect(-34, -56, 16, 22);
      ctx.fillStyle = skin;
      ctx.fillRect(-34, -56, 16, 4);
      ctx.fillRect(-34, -56, 4, 22);
      // Finger
      ctx.fillStyle = skinDark;
      for (let i = 0; i < 4; i++) {
        ctx.fillRect(-30 + i * 3, -52, 1, 16);
      }
      // Daumen
      ctx.fillStyle = skin;
      ctx.fillRect(-26, -58, 8, 4);
      ctx.fillStyle = skinShade;
      ctx.fillRect(-20, -58, 2, 4);

      // ===== Rechte Hand (am Stock/Griff, unten rechts) =====
      ctx.fillStyle = skinShade;
      ctx.fillRect(18, -10, 22, 26);
      ctx.fillStyle = skin;
      ctx.fillRect(18, -10, 22, 5);
      ctx.fillRect(18, -10, 5, 26);
      // Finger-Trennungen
      ctx.fillStyle = skinDark;
      for (let i = 0; i < 4; i++) {
        ctx.fillRect(23 + i * 4, -6, 1, 20);
      }
      // Daumen oben über Receiver
      ctx.fillStyle = skin;
      ctx.fillRect(18, -14, 10, 5);
      ctx.fillStyle = skinShade;
      ctx.fillRect(26, -14, 2, 5);

      // ===== Abzugbügel + Abzug =====
      ctx.fillStyle = metalDark;
      ctx.beginPath();
      ctx.ellipse(2, -8, 8, 9, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = wood;
      ctx.beginPath();
      ctx.ellipse(2, -7, 5, 6, 0, 0, Math.PI * 2);
      ctx.fill();
      // Trigger
      ctx.fillStyle = metalLite;
      ctx.fillRect(1, -10, 2, 5);

      // ===== Mündungsfeuer — kommt AUS den Mündungs-Öffnungen =====
      if (muzzleFlash > 0) {
        const a = Math.min(1, muzzleFlash / 90);
        ctx.globalAlpha = a;
        for (const bx of [-11, 11]) {
          // Großer orange Glow drumherum
          ctx.globalAlpha = a * 0.5;
          ctx.fillStyle = "#fb923c";
          ctx.beginPath();
          ctx.arc(bx, -95, 20, 0, Math.PI * 2);
          ctx.fill();
          ctx.globalAlpha = a;
          // Gelbe Stichflamme
          ctx.fillStyle = "#fbbf24";
          ctx.beginPath();
          ctx.moveTo(bx, -118);
          ctx.lineTo(bx - 11, -100);
          ctx.lineTo(bx - 6, -95);
          ctx.lineTo(bx - 9, -88);
          ctx.lineTo(bx - 3, -92);
          ctx.lineTo(bx, -84);
          ctx.lineTo(bx + 3, -92);
          ctx.lineTo(bx + 9, -88);
          ctx.lineTo(bx + 6, -95);
          ctx.lineTo(bx + 11, -100);
          ctx.closePath();
          ctx.fill();
          // Weißglühender Kern direkt an der Mündung
          ctx.fillStyle = "#fef9c3";
          ctx.beginPath();
          ctx.ellipse(bx, -92, 5, 7, 0, 0, Math.PI * 2);
          ctx.fill();
          // Hot spot direkt im Lauf-Loch
          ctx.fillStyle = "#fff";
          ctx.beginPath();
          ctx.ellipse(bx, -84, 3, 2, 0, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
      }

      ctx.restore();
    }

    // ---------- Update ----------
    function update(dt) {
      timeElapsed += dt;
      let mx = 0, my = 0;
      if (keys.w) my += 1;
      if (keys.s) my -= 1;
      if (keys.a) mx -= 1;
      if (keys.d) mx += 1;
      const mag = Math.hypot(mx, my);
      if (mag > 0) {
        mx /= mag; my /= mag;
        const cos = Math.cos(player.angle), sin = Math.sin(player.angle);
        const dx = (cos * my + (-sin) * mx) * player.moveSpeed * dt;
        const dy = (sin * my + (cos) * mx) * player.moveSpeed * dt;
        tryMove(dx, dy);
      }

      weapon.cooldown = Math.max(0, weapon.cooldown - dt * 1000);
      if (weapon.recoil > 0) weapon.recoil = Math.max(0, weapon.recoil - dt * 5);
      if (muzzleFlash > 0) muzzleFlash = Math.max(0, muzzleFlash - dt * 1000);
      if (damageFlash > 0) damageFlash = Math.max(0, damageFlash - dt * 1000);
      if (player.iFrames > 0) player.iFrames = Math.max(0, player.iFrames - dt * 1000);

      if (weapon.reloading) {
        weapon.reloadTimer -= dt * 1000;
        if (weapon.reloadTimer <= 0) {
          weapon.ammo = weapon.magSize;
          weapon.reloading = false;
        }
      }

      // Welle
      if (!waveActive && enemies.length === 0) {
        waveTimer += dt;
        if (waveTimer > 2.5) {
          waveTimer = 0;
          wave++;
          startWave(wave);
          document.getElementById("hud-wave").textContent = String(wave);
        }
      } else if (enemies.length === 0) {
        waveActive = false;
      }

      if (weapon.ammo === 0 && !weapon.reloading) tryReload();

      // Gegner
      for (let i = enemies.length - 1; i >= 0; i--) {
        const e = enemies[i];
        if (e.hitFlash > 0) e.hitFlash = Math.max(0, e.hitFlash - dt * 1000);
        if (e.atkCd > 0) e.atkCd = Math.max(0, e.atkCd - dt * 1000);

        const dx = player.x - e.x, dy = player.y - e.y;
        const d = Math.hypot(dx, dy);

        // Stöhnen — Lautstärke nach Distanz, Pan nach Richtung relativ zum Spieler
        e.groanTimer -= dt;
        if (e.groanTimer <= 0) {
          if (d < 15) {
            const cosP = Math.cos(player.angle), sinP = Math.sin(player.angle);
            // negativer dx/dy weil wir vom Spieler zum Gegner schauen
            const dxe = e.x - player.x, dye = e.y - player.y;
            const pan = Math.max(-1, Math.min(1, (-dxe * sinP + dye * cosP) / Math.max(1, d) * 0.85));
            playGroan(d, pan);
          }
          // Nächstes Stöhnen — näher = häufiger
          const proximityBonus = Math.max(0, 1 - d / 9); // 1.0 wenn direkt dran, 0 bei >=9 Feldern
          const base = 2.2 + Math.random() * 3.0; // 2.2–5.2 Sek
          e.groanTimer = base * (1 - proximityBonus * 0.55);
        }

        if (d > 0.001) {
          const nx = dx / d, ny = dy / d;
          const step = e.speed * dt;
          const newX = e.x + nx * step;
          const newY = e.y + ny * step;
          if (!isWall(newX, e.y)) e.x = newX;
          if (!isWall(e.x, newY)) e.y = newY;
        }
        if (d < e.r + 0.4 && e.atkCd <= 0 && player.iFrames <= 0) {
          player.hp -= e.dmg;
          e.atkCd = 800;
          player.iFrames = 400;
          damageFlash = 280;
          playHurt();
          if (player.hp <= 0) { player.hp = 0; endGame(); return; }
        }
      }
      for (let i = 0; i < enemies.length; i++) {
        for (let j = i + 1; j < enemies.length; j++) {
          const a = enemies[i], b = enemies[j];
          const dx = b.x - a.x, dy = b.y - a.y;
          const d = Math.hypot(dx, dy);
          const min = a.r + b.r;
          if (d > 0 && d < min) {
            const push = (min - d) / 2;
            const nx = dx / d, ny = dy / d;
            if (!isWall(a.x - nx * push * 0.4, a.y - ny * push * 0.4)) {
              a.x -= nx * push * 0.4; a.y -= ny * push * 0.4;
            }
            if (!isWall(b.x + nx * push * 0.4, b.y + ny * push * 0.4)) {
              b.x += nx * push * 0.4; b.y += ny * push * 0.4;
            }
          }
        }
      }

      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.x += p.vx * dt; p.y += p.vy * dt;
        p.ttl -= dt;
        if (p.ttl <= 0) particles.splice(i, 1);
      }
    }

    // ---------- HUD ----------
    const elWave = document.getElementById("hud-wave");
    const elKills = document.getElementById("hud-kills");
    const elTime = document.getElementById("hud-time");
    const elHp = document.getElementById("hud-hp");
    const elHpFill = document.getElementById("hud-hp-fill");
    const elAmmo = document.getElementById("hud-ammo");

    function fmtTime(s) {
      const m = Math.floor(s / 60);
      const r = Math.floor(s % 60);
      return m + ":" + String(r).padStart(2, "0");
    }
    function syncHud() {
      elWave.textContent = String(wave);
      elKills.textContent = String(player.kills);
      elTime.textContent = fmtTime(timeElapsed);
      elHp.textContent = String(Math.ceil(player.hp));
      elHpFill.style.transform = "scaleX(" + (player.hp / player.maxHp) + ")";
      elAmmo.textContent = weapon.reloading ? "RELOAD..." : (weapon.ammo + " / ∞");
    }

    // ---------- Loop ----------
    let lastT = 0;
    function loop(t) {
      if (!running) return;
      const dt = Math.min(0.05, (t - lastT) / 1000);
      lastT = t;
      if (!paused) {
        update(dt);
        if (!running) return;
      }
      render();
      syncHud();
      requestAnimationFrame(loop);
    }

    function reset() {
      enemies.length = 0;
      particles.length = 0;
      player.x = 7.5; player.y = 7.5; player.angle = 0; player.pitch = 0;
      player.hp = 100; player.maxHp = 100;
      player.kills = 0; player.score = 0; player.iFrames = 0;
      weapon.ammo = weapon.magSize;
      weapon.reloading = false; weapon.cooldown = 0; weapon.recoil = 0;
      wave = 0; waveTimer = 2.5; waveActive = false;
      timeElapsed = 0;
      muzzleFlash = 0; damageFlash = 0;
    }
    function startGame() {
      reset();
      document.getElementById("overlay-start").hidden = true;
      document.getElementById("overlay-gameover").hidden = true;
      document.getElementById("overlay-pause").hidden = true;
      running = true; paused = false;
      lastT = performance.now();
      requestAnimationFrame(loop);
      if (soundOn) ensureAudio();
      setTimeout(() => canvas.requestPointerLock?.(), 50);
    }
    function endGame() {
      running = false;
      document.exitPointerLock?.();
      document.getElementById("go-time").textContent = fmtTime(timeElapsed);
      document.getElementById("go-kills").textContent = String(player.kills);
      document.getElementById("go-wave").textContent = String(wave);
      const lines = [
        "Die Zombies feiern. Wahrscheinlich.",
        "Länger durchgehalten als so manche Production-Pipeline.",
        "Mehr Welle als Tickets am Sprint-Ende.",
        "Ein guter Lauf für jemanden, der die falsche URL erwischt hat.",
        "Zombies 1, du 0. Aber stilvoll verloren.",
      ];
      document.getElementById("go-line").textContent = lines[Math.floor(Math.random() * lines.length)];
      document.getElementById("overlay-gameover").hidden = false;
    }

    // Mobile-Hinweis: kein Spiel auf Touch-only Geräten
    const isTouchOnly = window.matchMedia &&
      window.matchMedia("(pointer: coarse)").matches &&
      !window.matchMedia("(pointer: fine)").matches;
    if (isTouchOnly) {
      document.getElementById("mobile-note").hidden = false;
      document.getElementById("overlay-start").hidden = true;
    }

    document.getElementById("btn-start").addEventListener("click", startGame);
    document.getElementById("btn-restart").addEventListener("click", startGame);
    document.getElementById("btn-resume").addEventListener("click", () => {
      canvas.requestPointerLock?.();
    });

    // Initiales Bild zeichnen
    render();
  })();
</script>
