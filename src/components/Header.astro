---
/**
 * Header — sticky, halbtransparent mit Blur.
 * Logo links, Navigation in der Mitte, Telefonnummer + CTA rechts.
 * Auf Mobile (< 768px) wird die Inline-Navigation und der "Erstgespräch"-CTA
 * ausgeblendet und stattdessen ein Burger-Menü angezeigt, das eine
 * Vollbild-Navigation aufklappt.
 */
import { site } from "../data/site";
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[rgba(10,10,10,0.7)] backdrop-blur-xl">
  <div class="container-content flex items-center justify-between py-4">
    <a href="/" class="text-lg font-bold tracking-tight">
      2FOX<span class="text-[var(--color-accent)]">4</span>
    </a>

    <nav class="hidden md:flex gap-8 text-sm text-[var(--color-text-muted)]">
      {site.nav.map((item) => (
        <a
          href={item.href}
          class="transition-colors hover:text-[var(--color-text)]"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={site.nap.phoneHref}
        class="hidden lg:flex items-center gap-2 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {site.nap.phoneDisplay}
      </a>

      {/* KI-Check — Akzent-Button (kostenloses Tool, Lead-Magnet) */}
      <a
        href="/ki-sichtbarkeit-check/"
        class="hidden md:inline-flex items-center gap-2 rounded-md bg-[var(--color-accent)] px-4 py-2 text-sm font-semibold text-black transition-all hover:-translate-y-px"
      >
        KI-Check
      </a>

      {/* Erstgespräch-CTA nur auf Desktop sichtbar — Mobile hat unten eigenen CTA-Block */}
      <a
        href="/kontakt/"
        class="hidden md:inline-flex items-center gap-2 rounded-md bg-white px-4 py-2 text-sm font-medium text-black transition-all hover:bg-white/85 hover:-translate-y-px"
      >
        Erstgespräch
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

      {/* Burger-Button — nur auf Mobile sichtbar */}
      <button
        type="button"
        id="mobile-menu-toggle"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-md border border-[var(--color-border)] text-[var(--color-text)] transition-colors hover:bg-white/5"
      >
        <svg id="mobile-menu-icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="mobile-menu-icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-5 h-5 hidden" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Mobile-Menü-Overlay */}
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-[var(--color-border)] bg-[rgba(10,10,10,0.95)] backdrop-blur-xl"
  >
    <nav class="container-content flex flex-col py-4">
      <a
        href="/ki-sichtbarkeit-check/"
        class="mb-3 inline-flex items-center justify-center gap-2 rounded-md bg-[var(--color-accent)] px-4 py-3 text-base font-semibold text-black"
      >
        KI-Sichtbarkeits-Check
      </a>
      {site.nav.map((item) => (
        <a
          href={item.href}
          class="py-3 text-base text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)] border-b border-[var(--color-border)] last:border-b-0"
        >
          {item.label}
        </a>
      ))}
      <a
        href={site.nap.phoneHref}
        class="mt-4 inline-flex items-center gap-2 text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        {site.nap.phoneDisplay}
      </a>
    </nav>
  </div>
</header>

<script>
  (function () {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const iconOpen = document.getElementById("mobile-menu-icon-open");
    const iconClose = document.getElementById("mobile-menu-icon-close");

    if (!toggle || !menu || !iconOpen || !iconClose) return;

    function setOpen(open) {
      if (!toggle || !menu || !iconOpen || !iconClose) return;
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      toggle.setAttribute("aria-label", open ? "Menü schließen" : "Menü öffnen");
      menu.classList.toggle("hidden", !open);
      iconOpen.classList.toggle("hidden", open);
      iconClose.classList.toggle("hidden", !open);
    }

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    // Schließen, wenn ein Link im Menü geklickt wird
    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    // Schließen mit ESC
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });

    // Bei Resize auf Desktop-Breite zurücksetzen
    const mq = window.matchMedia("(min-width: 768px)");
    mq.addEventListener("change", (e) => {
      if (e.matches) setOpen(false);
    });
  })();
</script>
