---
/**
 * CityHero — Hero-Variante für Stadt-Landingpages.
 * Kein 3D-Sphere, dafür eine Quick-Trust-Leiste mit Distanz/Erfahrung/etc.
 */

interface QuickTrustItem {
  iconSvg: string; // Inline-SVG (path-Inhalt, ohne <svg>-Wrapper)
  text: string; // HTML erlaubt für <strong>-Hervorhebung
}

interface Props {
  eyebrow: string;
  titleLine1: string;
  titleLine2: string;
  sub: string;
  quickTrust: QuickTrustItem[];
}

const { eyebrow, titleLine1, titleLine2, sub, quickTrust } = Astro.props;
---

<section class="relative overflow-hidden pt-22 pb-14">
  <div class="hero-grid-bg"></div>

  <div class="container-content relative z-10">
    <div class="inline-flex items-center gap-2.5 mb-7 px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] text-[var(--color-text-muted)]">
      <span class="pulse-dot inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-teal)]" style="box-shadow: 0 0 8px var(--color-teal);"></span>
      {eyebrow}
    </div>

    <h1 class="mb-6 max-w-[900px] text-[clamp(40px,6vw,72px)] font-bold tracking-[-0.04em] leading-[1.02]">
      <span class="text-gradient-light">{titleLine1}</span><br />
      <span class="text-gradient-accent">{titleLine2}</span>
    </h1>

    <p class="mb-9 max-w-[680px] text-[19px] leading-[1.65] text-[var(--color-text-muted)]">
      {sub}
    </p>

    <div class="flex flex-wrap gap-3 mb-10">
      <a
        href="#kontakt"
        class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3.5 text-[15px] font-medium text-black transition-all hover:-translate-y-px"
      >
        Kostenloses Erstgespräch
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7" />
        </svg>
      </a>
      <a
        href="tel:+4957259890175"
        class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border-strong)] bg-transparent px-6 py-3.5 text-[15px] font-medium text-[var(--color-text)] transition-all hover:bg-[var(--color-bg-card)]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
        </svg>
        05725 9890175
      </a>
    </div>

    <div class="flex flex-wrap gap-6 sm:gap-x-6 py-5 mt-4 text-sm text-[var(--color-text-muted)]">
      {quickTrust.map((item) => (
        <div class="flex items-center gap-2.5">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-[var(--color-accent-soft)] text-[var(--color-accent)]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-4 w-4" set:html={item.iconSvg} />
          </span>
          <span set:html={item.text} />
        </div>
      ))}
    </div>
  </div>
</section>
