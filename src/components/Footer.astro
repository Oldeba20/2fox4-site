---
/**
 * Footer — vollständiger NAP-Block, schnelllinks, Pflichtseiten.
 * Datenquelle: site.ts → einmal pflegen, überall korrekt.
 */
import { site } from "../data/site";

const currentYear = new Date().getFullYear();

// Social-Media-Icons. Key entspricht site.social[].name.
// Inhalt jeweils das <path>/<circle>-Innere eines 24x24-SVG ohne Wrapper.
const socialIcons: Record<string, string> = {
  facebook: `<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>`,
  linkedin: `<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`,
  instagram: `<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>`,
  youtube: `<path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>`,
  x: `<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>`,
  github: `<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>`,
};
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-elevated)] pt-16 pb-8">
  <div class="container-content">
    <div class="grid gap-12 md:grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] mb-12">
      {/* Brand + Social */}
      <div>
        <div class="text-lg font-bold tracking-tight">
          2FOX<span class="text-[var(--color-accent)]">4</span>
        </div>
        <p class="mt-3 max-w-[280px] text-sm leading-relaxed text-[var(--color-text-muted)]">
          Webdesign-Agentur mit Sitz in {site.nap.city}. Wir bauen Websites für
          Unternehmen aus Niedersachsen und ganz Deutschland.
        </p>

        {site.social && site.social.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2.5">
            {site.social.map((s) => (
              <a
                href={s.url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${s.label} (öffnet in neuem Tab)`}
                title={s.label}
                class="flex h-9 w-9 items-center justify-center rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] text-[var(--color-text-muted)] transition-all hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)] hover:-translate-y-0.5"
              >
                <svg
                  viewBox="0 0 24 24"
                  width="18"
                  height="18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  set:html={socialIcons[s.name] || ""}
                />
              </a>
            ))}
          </div>
        )}
      </div>

      {/* Leistungen */}
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-[var(--color-text)]">
          Leistungen
        </h5>
        <ul class="flex flex-col gap-2.5">
          {site.footer.leistungen.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Regional */}
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-[var(--color-text)]">
          Regional
        </h5>
        <ul class="flex flex-col gap-2.5">
          {site.footer.regional.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-[var(--color-text-muted)] transition-colors hover:text-[var(--color-text)]"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Kontakt / NAP */}
      <div>
        <h5 class="mb-4 text-[13px] font-semibold text-[var(--color-text)]">
          Kontakt
        </h5>
        <address class="not-italic text-sm leading-relaxed text-[var(--color-text-muted)]">
          <strong class="block mb-1 text-[var(--color-text)]">{site.nap.company}</strong>
          {site.nap.street}<br />
          {site.nap.zip} {site.nap.city}<br />
          <br />
          <a href={site.nap.phoneHref} class="hover:text-[var(--color-text)]">
            {site.nap.phoneDisplay}
          </a><br />
          <a href={site.nap.emailHref} class="hover:text-[var(--color-text)]">
            {site.nap.email}
          </a>
        </address>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-3 border-t border-[var(--color-border)] pt-6 text-[13px] text-[var(--color-text-faint)]">
      <div>© {currentYear} {site.name}</div>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {site.footer.pflicht.map((item) => {
          // Slug aus dem href ableiten: /impressum/ → impressum
          const slug = item.href.replace(/^\/+|\/+$/g, "");
          const isLegal = ["impressum", "datenschutz", "agb"].includes(slug);
          return (
            <a
              href={item.href}
              data-legal={isLegal ? slug : undefined}
              class="transition-colors hover:text-[var(--color-text)]"
            >
              {item.label}
            </a>
          );
        })}
        <button
          type="button"
          data-open-cookie-settings
          class="bg-transparent border-none p-0 cursor-pointer font-inherit text-[13px] text-[var(--color-text-faint)] transition-colors hover:text-[var(--color-text)]"
        >
          Cookie-Einstellungen
        </button>
      </div>
    </div>
  </div>
</footer>
