---
/**
 * NAPSection — Standort-Karte + Distanz-Block.
 * Distanz-Block ist optional; auf der allgemeinen Kontakt-Seite weglassen.
 */
import { site } from "../data/site";

interface Props {
  /** Distanz-Block z. B. `{ km: 9, note: "ca. 12 Min. über die L450" }` */
  distance?: { km: number; note: string; city?: string };
}

const { distance } = Astro.props;
---

<section id="kontakt" class="border-y border-[var(--color-border)] bg-[var(--color-bg-elevated)] py-24">
  <div class="container-content">
    <div class="grid items-center gap-14 lg:grid-cols-[1.2fr_1fr]">
      {/* NAP-Karte */}
      <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-9">
        <h4 class="mb-4 text-[13px] uppercase tracking-[0.14em] text-[var(--color-text-faint)]">
          Standort & Kontakt
        </h4>
        <div class="mb-1.5 text-[22px] font-semibold">{site.nap.company}</div>
        <div class="mb-7 text-[17px] leading-[1.6] text-[var(--color-text-muted)]">
          {site.nap.street}<br />
          {site.nap.zip} {site.nap.city}
        </div>

        <div class="flex items-center gap-3.5 border-t border-[var(--color-border)] py-3.5">
          <svg class="h-[18px] w-[18px] flex-shrink-0 text-[var(--color-text-faint)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
          </svg>
          <span class="mr-auto text-xs uppercase tracking-[0.1em] text-[var(--color-text-faint)]">Telefon</span>
          <a href={site.nap.phoneHref} class="text-base text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]">
            {site.nap.phoneDisplay}
          </a>
        </div>

        <div class="flex items-center gap-3.5 border-t border-[var(--color-border)] py-3.5">
          <svg class="h-[18px] w-[18px] flex-shrink-0 text-[var(--color-text-faint)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
            <polyline points="22,6 12,13 2,6" />
          </svg>
          <span class="mr-auto text-xs uppercase tracking-[0.1em] text-[var(--color-text-faint)]">E-Mail</span>
          <a href={site.nap.emailHref} class="text-base text-[var(--color-text)] transition-colors hover:text-[var(--color-accent)]">
            {site.nap.email}
          </a>
        </div>

        <div class="flex items-center gap-3.5 border-t border-[var(--color-border)] py-3.5">
          <svg class="h-[18px] w-[18px] flex-shrink-0 text-[var(--color-text-faint)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          <span class="mr-auto text-xs uppercase tracking-[0.1em] text-[var(--color-text-faint)]">Öffnungszeiten</span>
          <span class="text-base">Mo–Fr · 9-18 Uhr</span>
        </div>
      </div>

      {/* Distanz-Block (nur Stadt-Seiten) */}
      {distance && (
        <div>
          <div class="text-[80px] font-bold leading-none tracking-[-0.04em] text-gradient-accent">
            {distance.km}<small class="text-[28px] opacity-70"> km</small>
          </div>
          <div class="mt-2 text-[17px] text-[var(--color-text-muted)]">
            {distance.city
              ? `vom ${distance.city}er Marktplatz bis zu uns. ${distance.note}.`
              : distance.note}
          </div>
        </div>
      )}
    </div>
  </div>
</section>
