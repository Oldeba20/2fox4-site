---
/**
 * Hero — die große Eröffnungssektion auf der Startseite.
 * Zweispaltiges Layout: Text links, Team-Foto rechts mit künstlerisch
 * verzerrtem Border-Radius ("Blob"-Optik) und farbigem Akzent-Glow.
 *
 * Auf den Stadt-Seiten wird CityHero genutzt, dieser Hero bleibt der
 * Startseite vorbehalten.
 */
import { site } from "../data/site";

interface Props {
  eyebrow?: string;
  /** Zweizeiliger Titel: Zeile 1 weiß, Zeile 2 orange */
  titleLine1?: string;
  titleLine2?: string;
  sub?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Pfad zum Hero-Bild (optional — wenn weg, ein-spaltig zentriert) */
  photo?: { src: string; alt: string };
}

const {
  eyebrow = `Webagentur aus ${site.nap.city} · für Stadthagen, Bückeburg & Region`,
  titleLine1 = "Webdesign, das",
  titleLine2 = "auffindbar macht.",
  sub = "Wir bauen Websites für Unternehmen aus Stadthagen, Bückeburg, Wunstorf und der gesamten Region. Schnell, KI-gestützt, ehrlich. Kein Buzzword-Bingo, sondern messbare Auffindbarkeit bei Google.",
  primaryCta = { label: "Kostenloses Erstgespräch", href: "/kontakt/" },
  secondaryCta = { label: "Leistungen entdecken", href: "/leistungen/" },
  photo = {
    // Bild lokal gehostet — drei Formate (AVIF/WebP/JPG) im <picture> unten.
    // Pfad ohne Endung; Endungen werden im picture-Markup ergänzt.
    src: "/images/hero/oliver-deppe-buero.jpg",
    alt: "Oliver Deppe von 2FOX4 im Büro in Sachsenhagen — Kaffee in der Hand, Assistentin am Laptop. Echte Menschen, mit denen du dich gerne unterhältst.",
  },
} = Astro.props;

/**
 * Hero-Bild-Pfade ableiten für <picture>-Tag.
 * Beispiel: /images/hero/oliver-team-v2.jpg → .avif / .webp / .jpg
 * Senkt LCP um ca. 35-50 % auf Mobile (AVIF ist ~50% kleiner als JPG).
 */
const photoBase = photo.src.replace(/\.(jpe?g|png|webp|avif)$/i, "");
const photoSrcAvif = `${photoBase}.avif`;
const photoSrcWebp = `${photoBase}.webp`;
const photoSrcJpg = `${photoBase}.jpg`;
---

<section class="relative pt-20 pb-20 overflow-hidden">
  <div class="hero-grid-bg"></div>

  <div class="container-content relative z-10">
    {photo ? (
      <div class="grid items-center gap-12 lg:grid-cols-[1.15fr_1fr] lg:gap-16">
        {/* Text-Spalte (links) */}
        <div class="text-left">
          <div class="inline-flex items-center gap-2 mb-7 px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] text-[var(--color-text-muted)]">
            <span class="pulse-dot inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-teal)]" style="box-shadow: 0 0 8px var(--color-teal);"></span>
            {eyebrow}
          </div>

          <h1 class="text-[clamp(36px,5.5vw,68px)] font-bold tracking-[-0.04em] leading-[1.04] mb-6">
            <span class="text-gradient-light">{titleLine1}</span><br />
            <span class="text-gradient-accent">{titleLine2}</span>
          </h1>

          <p class="text-lg text-[var(--color-text-muted)] max-w-[560px] mb-9 leading-relaxed">
            {sub}
          </p>

          <div class="flex flex-wrap gap-3">
            <a
              href={primaryCta.href}
              class="inline-flex items-center gap-2 rounded-md bg-white px-5 py-3 text-[15px] font-medium text-black transition-all hover:bg-white/85 hover:-translate-y-px"
            >
              {primaryCta.label}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </a>
            <a
              href={secondaryCta.href}
              class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border-strong)] bg-transparent px-5 py-3 text-[15px] font-medium text-[var(--color-text)] transition-all hover:bg-[var(--color-bg-card)] hover:border-white/25"
            >
              {secondaryCta.label}
            </a>
          </div>
        </div>

        {/* Foto-Spalte (rechts) — modernes Bildformat via <picture>. Browser
            wählt das beste verfügbare Format (AVIF → WebP → JPG-Fallback). */}
        <div class="hero-photo-wrap">
          <span class="hero-photo-glow" aria-hidden="true"></span>
          <span class="hero-photo-dot" aria-hidden="true"></span>
          <div class="hero-photo-frame">
            <picture>
              <source type="image/avif" srcset={photoSrcAvif} />
              <source type="image/webp" srcset={photoSrcWebp} />
              <img
                src={photoSrcJpg}
                alt={photo.alt}
                width="800"
                height="800"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </picture>
          </div>
        </div>
      </div>
    ) : (
      <div class="text-center">
        <div class="inline-flex items-center gap-2 mb-8 px-3.5 py-1.5 rounded-full border border-[var(--color-border)] text-[13px] text-[var(--color-text-muted)]">
          <span class="pulse-dot inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-teal)]" style="box-shadow: 0 0 8px var(--color-teal);"></span>
          {eyebrow}
        </div>
        <h1 class="text-[clamp(40px,6.5vw,76px)] font-bold tracking-[-0.04em] leading-[1.02] mb-6">
          <span class="text-gradient-light">{titleLine1}</span><br />
          <span class="text-gradient-accent">{titleLine2}</span>
        </h1>
        <p class="text-lg text-[var(--color-text-muted)] max-w-[620px] mx-auto mb-10 leading-relaxed">
          {sub}
        </p>
        <div class="flex flex-wrap justify-center gap-3">
          <a href={primaryCta.href} class="inline-flex items-center gap-2 rounded-md bg-white px-5 py-3 text-[15px] font-medium text-black transition-all hover:bg-white/85 hover:-translate-y-px">
            {primaryCta.label}
          </a>
          <a href={secondaryCta.href} class="inline-flex items-center gap-2 rounded-md border border-[var(--color-border-strong)] bg-transparent px-5 py-3 text-[15px] font-medium text-[var(--color-text)] transition-all hover:bg-[var(--color-bg-card)] hover:border-white/25">
            {secondaryCta.label}
          </a>
        </div>
      </div>
    )}
  </div>
</section>

<style is:global>
  /* Künstlerisch verzerrter Foto-Container im Hero */
  .hero-photo-wrap {
    position: relative;
    width: 100%;
    max-width: 480px;
    margin: 0 auto;
    aspect-ratio: 1 / 1;
    isolation: isolate;
  }
  .hero-photo-frame {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    /* Asymmetrische Blob-Form — wirkt handgezeichnet, nicht steril */
    border-radius: 62% 38% 54% 46% / 42% 58% 42% 58%;
    border: 1px solid var(--color-border-strong);
    transform: rotate(-2deg);
    box-shadow:
      0 30px 80px -20px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255, 255, 255, 0.03) inset;
    transition: transform 0.5s ease;
  }
  .hero-photo-frame:hover { transform: rotate(-2deg) scale(1.02); }
  .hero-photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: rotate(2deg) scale(1.06); /* Foto leicht gegenrotiert, damit Personen gerade stehen */
  }
  /* Farbiger Akzent-Glow dahinter */
  .hero-photo-glow {
    position: absolute;
    inset: -18% -12% -12% -18%;
    background: radial-gradient(
      circle at 30% 35%,
      rgba(255, 91, 31, 0.32) 0%,
      rgba(255, 91, 31, 0.0) 55%
    );
    filter: blur(34px);
    z-index: -2;
    pointer-events: none;
  }
  /* Zweiter, kühler Akzent-Punkt unten rechts */
  .hero-photo-dot {
    position: absolute;
    right: -8%;
    bottom: -6%;
    width: 42%;
    height: 42%;
    background: radial-gradient(
      circle,
      rgba(64, 224, 208, 0.22) 0%,
      rgba(64, 224, 208, 0.0) 65%
    );
    filter: blur(28px);
    z-index: -1;
    pointer-events: none;
  }
  /* Bei reduzierter Bewegung: Tilt + Hover-Animation aus */
  @media (prefers-reduced-motion: reduce) {
    .hero-photo-frame, .hero-photo-frame:hover { transform: none; }
    .hero-photo-frame img { transform: none; }
  }
</style>
