---
/**
 * MonitorCard — Browser-Fenster-Optik mit Traffic-Lights und URL-Bar.
 * Wird sowohl auf Stadt-Landingpages (lokale Referenzen) als auch
 * auf der Referenzen-Übersichtsseite verwendet.
 *
 * Props:
 *   url      — Anzeige in der URL-Bar (ohne Protokoll, z. B. "renaissance-stadthagen.de")
 *   image    — Quelle des Vorschau-Bilds der "Screen"-Fläche
 *   alt      — Alt-Text für das Vorschau-Bild (SEO + a11y). Fallback aus URL.
 *   href     — Wohin verlinkt die Karte
 *   variant  — "compact" (Stadt-Seite) oder "default" (Referenzen, mit Hover-Zoom)
 *
 * Wichtig (Mai 2026 Refactor): Das Vorschau-Bild wird jetzt als <img>-Tag
 * gerendert statt als CSS background-image. Damit kommt es in die Google-
 * Bildersuche und hat einen alt-Text für Screenreader.
 */
interface Props {
  url: string;
  image: string;
  alt?: string;
  /** Wenn href fehlt: Karte wird als <div> gerendert (nicht klickbar). */
  href?: string;
  variant?: "compact" | "default";
}

const { url, image, alt, href, variant = "default" } = Astro.props;
const Tag = href ? "a" : "div";
// Fallback-Alt aus der URL — besser als leer.
const imageAlt = alt ?? `Vorschau der Website ${url}`;
---

<Tag
  class:list={["monitor-card", variant, !href && "monitor-card--static"]}
  href={href}
  data-variant={variant}
>
  <div class="monitor">
    <div class="monitor-top">
      <div class="traffic">
        <span class="red"></span>
        <span class="yellow"></span>
        <span class="green"></span>
      </div>
      <div class="url-bar">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2" />
          <path d="M7 11V7a5 5 0 0 1 10 0v4" />
        </svg>
        {url}
      </div>
    </div>
    <div class="screen">
      <img src={image} alt={imageAlt} loading="lazy" decoding="async" class="screen-img" />
      <div class="screen-glare"></div>
      <div class="screen-tint"></div>
    </div>
  </div>
  <div class="info">
    <slot />
  </div>
</Tag>

